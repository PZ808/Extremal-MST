       RowBox[{"yout", "[", "R", "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"R", ",", "0", ",", "5"}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"yinSolver", "[", 
     RowBox[{
     "sval_", ",", "lval_", ",", "mval_", ",", "\[Omega]hatval_", ",", 
