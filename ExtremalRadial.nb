Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"NH", " ", "sampling"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"nbrr", "=", "100"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"step", "=", 
     RowBox[{"SetPrecision", "[", 
      RowBox[{
       RowBox[{"1", "/", "10"}], ",", "PREC"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"tr", "=", 
     RowBox[{"N", "[", 
      RowBox[{
       RowBox[{"rH", 
        RowBox[{"(", 
         RowBox[{"1", "+", 
          RowBox[{"10", "^", 
           RowBox[{"Range", "[", 
            RowBox[{
             RowBox[{"-", "11"}], ",", 
             RowBox[{"-", "1"}], ",", 
             RowBox[{"(", 
              RowBox[{"10", "/", 
               RowBox[{"(", 
                RowBox[{"nbrr", "-", "1"}], ")"}]}], ")"}]}], "]"}]}]}], 
         ")"}]}], ",", " ", "PREC"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"For", "[", 
     RowBox[{
      RowBox[{"i", "=", "1"}], ",", 
      RowBox[{"i", "<", "nbrr"}], ",", 
      RowBox[{"i", "++"}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{"X", "[", "i", "]"}], "=", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"x", "[", 
           RowBox[{"tr", "[", 
            RowBox[{"[", "i", "]"}], "]"}], "]"}], ",", 
          RowBox[{"tr", "[", 
           RowBox[{"[", "i", "]"}], "]"}]}], "}"}]}], ";"}]}], "]"}], ";"}], 
   "\n", 
   RowBox[{
    RowBox[{"XnearVals", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"X", "[", 
        RowBox[{"nbrr", "-", "i"}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "1", ",", 
         RowBox[{"nbrr", "-", "2"}]}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"FH", " ", "sampling"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{"For", "[", 
    RowBox[{
     RowBox[{"i", "=", "2"}], ",", 
     RowBox[{"i", "<", "5000"}], ",", 
     RowBox[{"i", "++"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"X", "[", "i", "]"}], "=", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"N", "[", 
          RowBox[{
           RowBox[{"x", "[", 
            RowBox[{"rH", " ", 
             RowBox[{"(", 
              RowBox[{"1", "+", 
               RowBox[{"step", " ", "i"}]}], ")"}]}], "]"}], ",", "PREC"}], 
          "]"}], ",", 
         RowBox[{"N", "[", 
          RowBox[{
           RowBox[{"rH", " ", 
            RowBox[{"(", 
             RowBox[{"1", "+", 
              RowBox[{"step", " ", "i"}]}], ")"}]}], ",", "PREC"}], "]"}]}], 
        "}"}]}], ";"}]}], "\[IndentingNewLine]", "]"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"XfarVals", "=", 
     RowBox[{"Table", " ", "[", 
      RowBox[{
       RowBox[{"X", "[", "i", "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "2", ",", "4999"}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Xvals", "=", 
     RowBox[{"Join", "[", 
      RowBox[{"XnearVals", ",", "XfarVals"}], "]"}]}], ";"}], 
   RowBox[{"(*", 
    RowBox[{"Inverted", " ", "tortoise", " ", "table"}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{"Clear", "[", 
    RowBox[{"tr", ",", "XnearVals", ",", "XfarVals"}], "]"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"rInterp", "=", 
     RowBox[{"Interpolation", "[", 
      RowBox[{"Xvals", ",", 
       RowBox[{"InterpolationOrder", "->", "3"}]}], "]"}]}], ";"}], " ", 
   RowBox[{"(*", 
    RowBox[{"Inverted", " ", "tortoise", " ", "function"}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"{", 
      RowBox[{"xminTab", ",", "xmaxTab"}], "}"}], "=", 
     RowBox[{"MinMax", "[", 
      RowBox[{"Xvals", "[", 
       RowBox[{"[", 
        RowBox[{"All", ",", "1"}], "]"}], "]"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"{", 
      RowBox[{"xInterpMin", ",", "xInterpMax"}], "}"}], "=", 
     RowBox[{
      RowBox[{"rInterp", "[", "\"\<Domain\>\"", "]"}], "[", 
      RowBox[{"[", "1", "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"xminUse", "=", 
     RowBox[{"Max", "[", 
      RowBox[{
       RowBox[{"-", "150"}], ",", "xInterpMin"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"xmaxUse", "=", "xInterpMax"}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"VeffInter", "[", 
      RowBox[{"om_", ",", "m_", ",", "l_"}], "]"}], "[", "x_", "]"}], ":=", 
    RowBox[{"VeffREx", "[", 
     RowBox[{
      RowBox[{"rInterp", "[", "x", "]"}], ",", "M", ",", "m", ",", "om", ",", 
      RowBox[{"lamSNEx", "[", 
       RowBox[{"l", ",", " ", "m", ",", " ", "om", ",", " ", "M"}], "]"}]}], 
     "]"}]}], "\[IndentingNewLine]", 
   RowBox[{"Clear", "[", "Zfun", "]"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"Zfun", "[", 
      RowBox[{"\[Omega]_", ",", "l_", ",", "m_"}], "]"}], ":=", 
     RowBox[{"NDSolveValue", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"Z", "''"}], "[", "x", "]"}], "+", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{
              RowBox[{"\[Omega]", "^", "2"}], "-", 
              RowBox[{
               RowBox[{"VeffInter", "[", 
                RowBox[{"\[Omega]", ",", "m", ",", "l"}], "]"}], "[", "x", 
               "]"}]}], ")"}], " ", 
            RowBox[{"Z", "[", "x", "]"}]}]}], "==", "0"}], ",", 
         RowBox[{
          RowBox[{"Z", "[", "xminUse", "]"}], "==", "1"}], ",", 
         RowBox[{
          RowBox[{
           RowBox[{"Z", "'"}], "[", "xminUse", "]"}], "==", 
          RowBox[{
           RowBox[{"-", "I"}], " ", 
           RowBox[{"(", 
            RowBox[{"\[Omega]", "-", 
             FractionBox["m", "2"]}], " ", ")"}]}]}]}], "}"}], ",", "Z", ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", "xminUse", ",", "xmaxUse"}], "}"}], ",", 
       RowBox[{"WorkingPrecision", "->", "40"}], ",", 
       RowBox[{"AccuracyGoal", "->", "20"}], ",", 
       RowBox[{"PrecisionGoal", "->", "20"}], ",", 
       RowBox[{"MaxSteps", "->", "Infinity"}]}], "]"}]}], ";"}]}]}]], "Input",
 CellChangeTimes->{{3.983177887191235*^9, 3.983177896715423*^9}, {
   3.98317803610576*^9, 3.983178037882936*^9}, {3.9831783537876387`*^9, 
