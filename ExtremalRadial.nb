Cell[BoxData[{
 RowBox[{
  RowBox[{"\[CapitalDelta]", "=", 
   RowBox[{
    SuperscriptBox["r", "2"], "-", 
    RowBox[{"2", "M", "*", "r"}], "+", 
    SuperscriptBox["a", "2"]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"kext", "=", 
   RowBox[{"\[Omega]", "-", 
    FractionBox["m", 
     RowBox[{"2", "M"}]]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"eqR", "=", 
   RowBox[{
    RowBox[{
     RowBox[{
      SuperscriptBox["\[CapitalDelta]", 
       RowBox[{"-", "s"}]], "*", 
      RowBox[{"D", "[", 
       RowBox[{
        RowBox[{
         SuperscriptBox["\[CapitalDelta]", 
          RowBox[{"s", "+", "1"}]], "*", 
         RowBox[{"D", "[", 
          RowBox[{
           RowBox[{"R", "[", "r", "]"}], ",", "r"}], "]"}]}], ",", "r"}], 
       "]"}]}], "+", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        FractionBox[
         RowBox[{
          SuperscriptBox["K", "2"], "-", 
          RowBox[{"2", "*", "I", "*", "s", "*", 
           RowBox[{"(", 
            RowBox[{"r", "-", "M"}], ")"}], "*", "K"}]}], "\[CapitalDelta]"], 
        "+", 
        RowBox[{"4", "*", "I", "*", "s", "*", "\[Omega]", "*", "r"}], "-", 
        "\[Lambda]"}], ")"}], "*", 
      RowBox[{"R", "[", "r", "]"}]}]}], "/.", 
    RowBox[{"K", "->", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         SuperscriptBox["r", "2"], "+", 
         SuperscriptBox["a", "2"]}], ")"}], "*", "\[Omega]"}], "-", 
      RowBox[{"a", "*", "m"}]}]}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"eqR", "/.", 
       RowBox[{"a", "->", "M"}]}], "/.", 
      RowBox[{"R", "->", 
       RowBox[{"Function", "[", 
        RowBox[{"r", ",", 
         RowBox[{
          SuperscriptBox[
           RowBox[{"(", 
            RowBox[{"-", "1"}], ")"}], "s"], "*", 
          SuperscriptBox[
           RowBox[{"(", 
            RowBox[{"r", "-", "M"}], ")"}], 
           RowBox[{
            RowBox[{
             RowBox[{"-", "2"}], "s"}], "-", 
            RowBox[{"2", "I", "*", "\[Omega]", "*", "M"}]}]], "*", 
          RowBox[{"Exp", "[", 
           FractionBox[
            RowBox[{"2", "I", "*", "kext", "*", 
             SuperscriptBox["M", "2"]}], 
            RowBox[{"r", "-", "M"}]], "]"}], "*", 
          RowBox[{"yin", "[", "r", "]"}]}]}], "]"}]}]}], "/.", 
     RowBox[{"yin", "->", 
      RowBox[{"Function", "[", 
       RowBox[{"r", ",", 
        RowBox[{"yin", "[", 
         RowBox[{
          FractionBox["r", "M"], "-", "1"}], "]"}]}], "]"}]}]}], "/.", 
    RowBox[{"r", "->", 
     RowBox[{"M", 
      RowBox[{"(", 
       RowBox[{"1", "+", "R"}], ")"}]}]}]}], "//", "Simplify"}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"eqyin", "=", 
   RowBox[{"Collect", "[", 
    RowBox[{
     RowBox[{
      SuperscriptBox["R", "2"], "*", 
      FractionBox["%", 
       RowBox[{"Coefficient", "[", 
        RowBox[{"%", ",", 
         RowBox[{
          RowBox[{"yin", "''"}], "[", "R", "]"}]}], "]"}]]}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"yin", "[", "R", "]"}], ",", 
       RowBox[{
        RowBox[{"yin", "'"}], "[", "R", "]"}], ",", 
       RowBox[{
        RowBox[{"yin", "''"}], "[", "R", "]"}]}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"eqR", "/.", 
       RowBox[{"a", "->", "M"}]}], "/.", 
      RowBox[{"R", "->", 
       RowBox[{"Function", "[", 
        RowBox[{"r", ",", 
         RowBox[{
          SuperscriptBox[
           RowBox[{"(", 
            RowBox[{"r", "-", "M"}], ")"}], 
           RowBox[{"2", "I", "*", "\[Omega]", "*", "M"}]], "*", 
          RowBox[{"Exp", "[", 
           RowBox[{"-", 
            FractionBox[
             RowBox[{"2", "I", "*", "kext", "*", 
              SuperscriptBox["M", "2"]}], 
             RowBox[{"r", "-", "M"}]]}], "]"}], "*", 
          RowBox[{"yout", "[", "r", "]"}]}]}], "]"}]}]}], "/.", 
     RowBox[{"yout", "->", 
      RowBox[{"Function", "[", 
       RowBox[{"r", ",", 
        RowBox[{"yout", "[", 
         RowBox[{
          FractionBox["r", "M"], "-", "1"}], "]"}]}], "]"}]}]}], "/.", 
    RowBox[{"r", "->", 
     RowBox[{"M", 
      RowBox[{"(", 
       RowBox[{"1", "+", "R"}], ")"}]}]}]}], "//", "Simplify"}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[ScriptCapitalL]", "[", "y", "]"}], "==", 
  RowBox[{"(", 
   RowBox[{"eqyout", "=", 
    RowBox[{"Collect", "[", 
     RowBox[{
      RowBox[{
       SuperscriptBox["R", "2"], "*", 
       FractionBox["%", 
        RowBox[{"Coefficient", "[", 
         RowBox[{"%", ",", 
          RowBox[{
           RowBox[{"yout", "''"}], "[", "R", "]"}]}], "]"}]]}], ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"yout", "[", "R", "]"}], ",", 
        RowBox[{
         RowBox[{"yout", "'"}], "[", "R", "]"}], ",", 
        RowBox[{
         RowBox[{"yout", "''"}], "[", "R", "]"}]}], "}"}]}], "]"}]}], 
   ")"}]}]}], "Input",
