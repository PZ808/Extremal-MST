Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"generate", " ", "the", " ", "asymptotic", " ", "solutions"}], " ",
    "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"Clear", "[", 
    RowBox[{
    "yinAsym", ",", "youtAsym", ",", "yinSolver", ",", "youtSolver", ",", 
     "yinSolverInterp", ",", "youtSolverInterp"}], "]"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"yinAsym", "=", 
     RowBox[{"AsymptoticDSolveValue", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"eqyin", "==", "0"}], ",", 
         RowBox[{
          RowBox[{"yin", "[", "0", "]"}], "==", "1"}]}], "}"}], ",", 
       RowBox[{"yin", "[", "R", "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"R", ",", "0", ",", "5"}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"youtAsym", "=", 
     RowBox[{"AsymptoticDSolveValue", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"eqyout", "==", "0"}], ",", 
         RowBox[{
          RowBox[{"yout", "[", "0", "]"}], "==", "1"}]}], "}"}], ",", 
       RowBox[{"yout", "[", "R", "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"R", ",", "0", ",", "5"}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"yinSolver", "[", 
     RowBox[{
     "sval_", ",", "lval_", ",", "mval_", ",", "\[Omega]hatval_", ",", 
      "\[Lambda]val_", ",", "\[Epsilon]_"}], "]"}], ":=", 
    RowBox[{"Block", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"M", "=", "1"}], "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{"With", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"yinval", "=", 
           RowBox[{"yinAsym", "/.", 
            RowBox[{"R", "->", "\[Epsilon]"}]}]}], ",", 
          RowBox[{"yinp", "=", 
           RowBox[{
            RowBox[{"D", "[", 
             RowBox[{"yinAsym", ",", "R"}], "]"}], "/.", 
            RowBox[{"R", "->", "\[Epsilon]"}]}]}]}], "}"}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{"First", "@", 
         RowBox[{"NDSolve", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{"eqyin", "==", "0"}], ",", 
              RowBox[{
               RowBox[{
                RowBox[{"yin", "'"}], "[", "\[Epsilon]", "]"}], "==", 
               "yinp"}], ",", 
              RowBox[{
               RowBox[{"yin", "[", "\[Epsilon]", "]"}], "==", "yinval"}]}], 
             "}"}], "/.", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"s", "->", "sval"}], ",", 
              RowBox[{"l", "->", "lval"}], ",", 
              RowBox[{"m", "->", "mval"}], ",", 
              RowBox[{"\[Omega]", "->", 
               FractionBox[
                RowBox[{"\[Omega]hatval", "+", "mval"}], 
                RowBox[{"2", "M"}]]}], ",", 
              RowBox[{"\[Lambda]", "->", "\[Lambda]val"}]}], "}"}]}], ",", 
           "yin", ",", 
           RowBox[{"{", 
            RowBox[{"R", ",", "\[Epsilon]", ",", "RouterBoundary"}], "}"}]}], 
          "]"}]}]}], "]"}]}], "]"}]}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"youtSolver", "[", 
     RowBox[{
     "sval_", ",", "lval_", ",", "mval_", ",", "\[Omega]hatval_", ",", 
      "\[Lambda]val_", ",", "\[Epsilon]_"}], "]"}], ":=", 
    RowBox[{"Block", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"M", "=", "1"}], "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{"With", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"youtval", "=", 
           RowBox[{"youtAsym", "/.", 
            RowBox[{"R", "->", "\[Epsilon]"}]}]}], ",", 
          RowBox[{"youtp", "=", 
           RowBox[{
            RowBox[{"D", "[", 
             RowBox[{"youtAsym", ",", "R"}], "]"}], "/.", 
            RowBox[{"R", "->", "\[Epsilon]"}]}]}]}], "}"}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{"First", "@", 
         RowBox[{"NDSolve", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{"eqyout", "==", "0"}], ",", 
              RowBox[{
               RowBox[{
                RowBox[{"yout", "'"}], "[", "\[Epsilon]", "]"}], "==", 
               "youtp"}], ",", 
              RowBox[{
               RowBox[{"yout", "[", "\[Epsilon]", "]"}], "==", "youtval"}]}], 
             "}"}], "/.", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"s", "->", "sval"}], ",", 
              RowBox[{"l", "->", "lval"}], ",", 
              RowBox[{"m", "->", "mval"}], ",", 
              RowBox[{"\[Omega]", "->", 
               FractionBox[
                RowBox[{"\[Omega]hatval", "+", "mval"}], 
                RowBox[{"2", "M"}]]}], ",", 
              RowBox[{"\[Lambda]", "->", "\[Lambda]val"}]}], "}"}]}], ",", 
           "yout", ",", 
           RowBox[{"{", 
            RowBox[{"R", ",", "\[Epsilon]", ",", "RouterBoundary"}], "}"}]}], 
          "]"}]}]}], "]"}]}], "]"}]}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"yinSolverInterp", "[", 
     RowBox[{
     "sval_", ",", "lval_", ",", "mval_", ",", "\[Omega]hatval_", ",", 
      "\[Lambda]val_", ",", "\[Epsilon]_"}], "]"}], ":=", 
    RowBox[{"Block", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"M", "=", "1"}], "}"}], ",", 
      RowBox[{"With", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"yinval", "=", 
           RowBox[{"yinAsym", "/.", " ", 
            RowBox[{"R", "->", "\[Epsilon]"}]}]}], ",", 
          RowBox[{"yinp", "=", 
           RowBox[{
            RowBox[{"D", "[", 
             RowBox[{"yinAsym", ",", "R"}], "]"}], "/.", " ", 
            RowBox[{"R", "->", "\[Epsilon]"}]}]}]}], "}"}], ",", 
        RowBox[{"NDSolveValue", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"{", 
            RowBox[{
