Cell[BoxData[{
 RowBox[{"Clear", "[", 
  RowBox[{
  "Xvals", ",", "XnearVals", ",", "XfarVals", ",", "tr", ",", "step"}], 
  "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"NH", " ", "sampling"}], "*)"}], " ", 
  RowBox[{
   RowBox[{"nbrr", "=", "100"}], ";", 
   RowBox[{"step", "=", 
    RowBox[{"SetPrecision", "[", 
     RowBox[{
      RowBox[{"1", "/", "10"}], ",", "PREC"}], "]"}]}], ";", 
   RowBox[{"tr", "=", 
    RowBox[{"N", "[", 
     RowBox[{
      RowBox[{"rH", " ", 
       RowBox[{"(", 
        RowBox[{"1", "+", 
         RowBox[{"10", "^", 
          RowBox[{"Range", "[", 
           RowBox[{
            RowBox[{"-", "11"}], ",", 
            RowBox[{"-", "1"}], ",", 
            RowBox[{"(", 
             RowBox[{"10", "/", 
              RowBox[{"(", 
               RowBox[{"nbrr", "-", "1"}], ")"}]}], ")"}]}], "]"}]}]}], 
        ")"}]}], ",", "PREC"}], "]"}]}], ";", 
   RowBox[{"For", "[", 
    RowBox[{
     RowBox[{"i", "=", "1"}], ",", 
     RowBox[{"i", "<", "nbrr"}], ",", 
     RowBox[{"i", "++"}], ",", 
     RowBox[{
      RowBox[{
       RowBox[{"X", "[", "i", "]"}], "=", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"x", "[", 
          RowBox[{"tr", "[", 
           RowBox[{"[", "i", "]"}], "]"}], "]"}], ",", 
         RowBox[{"tr", "[", 
          RowBox[{"[", "i", "]"}], "]"}]}], "}"}]}], ";"}]}], "]"}], ";", 
   RowBox[{"XnearVals", "=", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"X", "[", 
       RowBox[{"nbrr", "-", "i"}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", "1", ",", 
        RowBox[{"nbrr", "-", "2"}]}], "}"}]}], "]"}]}], ";"}], 
  RowBox[{"(*", 
   RowBox[{"FH", " ", "sampling"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"For", "[", 
   RowBox[{
    RowBox[{"i", "=", "2"}], ",", 
    RowBox[{"i", "<", "5000"}], ",", 
    RowBox[{"i", "++"}], ",", 
    RowBox[{
     RowBox[{
      RowBox[{"X", "[", "i", "]"}], "=", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"N", "[", 
         RowBox[{
          RowBox[{"x", "[", 
           RowBox[{"rH", " ", 
            RowBox[{"(", 
             RowBox[{"1", "+", 
              RowBox[{"step", " ", "i"}]}], ")"}]}], "]"}], ",", "PREC"}], 
         "]"}], ",", 
        RowBox[{"N", "[", 
         RowBox[{
          RowBox[{"rH", " ", 
           RowBox[{"(", 
            RowBox[{"1", "+", 
             RowBox[{"step", " ", "i"}]}], ")"}]}], ",", "PREC"}], "]"}]}], 
       "}"}]}], ";"}]}], "]"}], " ", 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
