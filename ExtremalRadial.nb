Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"ClearAll", "[", 
    RowBox[{"fitFarScalarWave$S0", ",", "genGB$S0"}], "]"}], ";"}], 
  "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"fitFarScalarWave$S0", "[", 
    RowBox[{"Zfun_", ",", 
     RowBox[{"\[Omega]_", "?", "NumericQ"}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"x1_", "?", "NumericQ"}], ",", 
       RowBox[{"x2_", "?", "NumericQ"}]}], "}"}], ",", 
     RowBox[{"n_Integer", ":", "400"}]}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "xData", ",", "yData", ",", "mat", ",", "coeffs", ",", "resid"}], "}"}],
      ",", 
     RowBox[{
      RowBox[{"xData", "=", 
       RowBox[{"Subdivide", "[", 
        RowBox[{"x1", ",", "x2", ",", "n"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"yData", "=", 
       RowBox[{"Zfun", "/@", "xData"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"mat", "=", 
       RowBox[{"Transpose", "@", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"Exp", "[", 
           RowBox[{"I", " ", "\[Omega]", " ", "xData"}], "]"}], ",", 
          RowBox[{"Exp", "[", 
           RowBox[{
            RowBox[{"-", "I"}], " ", "\[Omega]", " ", "xData"}], "]"}]}], 
         "}"}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"coeffs", "=", 
       RowBox[{"LeastSquares", "[", 
        RowBox[{"mat", ",", "yData"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"resid", "=", 
       RowBox[{
        RowBox[{"Norm", "[", 
         RowBox[{
          RowBox[{"mat", ".", "coeffs"}], "-", "yData"}], "]"}], "/", 
        RowBox[{"Norm", "[", "yData", "]"}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"<|", 
       RowBox[{
        RowBox[{"\"\<Aout\>\"", "->", 
         RowBox[{"coeffs", "[", 
          RowBox[{"[", "1", "]"}], "]"}]}], ",", 
        RowBox[{"\"\<Ain\>\"", "->", 
         RowBox[{"coeffs", "[", 
          RowBox[{"[", "2", "]"}], "]"}]}], ",", 
        RowBox[{"\"\<Residual\>\"", "->", "resid"}], ",", 
        RowBox[{"\"\<xData\>\"", "->", "xData"}], ",", 
        RowBox[{"\"\<yData\>\"", "->", "yData"}]}], "|>"}]}]}], "]"}]}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{"genGB$S0", "[", 
   RowBox[{"\[Omega]List_", ",", "l_Integer", ",", "m_Integer", ",", 
    RowBox[{"xmin_", "?", "NumericQ"}], ",", 
    RowBox[{"xmax_", "?", "NumericQ"}], ",", 
    RowBox[{"fitWidth_", ":", "100"}], ",", 
    RowBox[{"nFit_Integer", ":", "400"}]}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"\[CapitalOmega]H", "=", 
      RowBox[{"1", "/", 
       RowBox[{"(", 
        RowBox[{"2", " ", "M"}], ")"}]}]}], "}"}], ",", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"Module", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
         "\[Omega]", ",", "kH", ",", "Zfun", ",", "fit", ",", "x1", ",", "x2",
           ",", "Ain", ",", "Aout", ",", "\[CapitalGamma]1", ",", 
          "\[CapitalGamma]2"}], "}"}], ",", 
        RowBox[{
         RowBox[{"\[Omega]", "=", 
          RowBox[{"\[Omega]List", "[", 
           RowBox[{"[", "j", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"kH", "=", 
          RowBox[{"\[Omega]", "-", 
           RowBox[{"m", " ", "\[CapitalOmega]H"}]}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"Zfun", "=", 
          RowBox[{"NDSolveValue", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{
               RowBox[{
                RowBox[{
                 RowBox[{"Z", "''"}], "[", "x", "]"}], "+", 
                RowBox[{
                 RowBox[{"(", 
                  RowBox[{
                   RowBox[{"\[Omega]", "^", "2"}], "-", 
                   RowBox[{
                    RowBox[{"VeffInterScalar", "[", 
                    RowBox[{"\[Omega]", ",", "m", ",", "l"}], "]"}], "[", "x",
                     "]"}]}], ")"}], " ", 
                 RowBox[{"Z", "[", "x", "]"}]}]}], "==", "0"}], ",", 
              RowBox[{
               RowBox[{"Z", "[", "xmin", "]"}], "==", 
               RowBox[{"Exp", "[", 
                RowBox[{
                 RowBox[{"-", "I"}], " ", "kH", " ", "xmin"}], "]"}]}], ",", 
              RowBox[{
               RowBox[{
                RowBox[{"Z", "'"}], "[", "xmin", "]"}], "==", 
               RowBox[{
                RowBox[{"-", "I"}], " ", "kH", " ", 
                RowBox[{"Exp", "[", 
                 RowBox[{
                  RowBox[{"-", "I"}], " ", "kH", " ", "xmin"}], "]"}]}]}]}], 
             "}"}], ",", "Z", ",", 
            RowBox[{"{", 
             RowBox[{"x", ",", "xmin", ",", "xmax"}], "}"}], ",", 
            RowBox[{"MaxSteps", "->", "Infinity"}]}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"x1", "=", 
          RowBox[{"xmax", "-", "fitWidth"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"x2", "=", "xmax"}], ";", "\[IndentingNewLine]", 
         RowBox[{"fit", "=", 
          RowBox[{"fitFarScalarWave$S0", "[", 
           RowBox[{"Zfun", ",", "\[Omega]", ",", 
            RowBox[{"{", 
             RowBox[{"x1", ",", "x2"}], "}"}], ",", "nFit"}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"Aout", "=", 
          RowBox[{"fit", "[", "\"\<Aout\>\"", "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"Ain", "=", 
          RowBox[{"fit", "[", "\"\<Ain\>\"", "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"\[CapitalGamma]1", "=", 
          RowBox[{"1", "-", 
           RowBox[{
            RowBox[{"Abs", "[", 
             RowBox[{"Aout", "/", "Ain"}], "]"}], "^", "2"}]}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"\[CapitalGamma]2", "=", 
          RowBox[{"kH", "/", 
           RowBox[{"(", 
            RowBox[{"\[Omega]", " ", 
             RowBox[{
              RowBox[{"Abs", "[", "Ain", "]"}], "^", "2"}]}], ")"}]}]}], ";", 
         RowBox[{"(*", 
          RowBox[{
          "should", " ", "agree", " ", "with", " ", "\[CapitalGamma]1"}], 
          "*)"}], 
         RowBox[{"<|", 
          RowBox[{
           RowBox[{"\"\<\[Omega]\>\"", "->", "\[Omega]"}], ",", 
           RowBox[{"\"\<kH\>\"", "->", "kH"}], ",", 
           RowBox[{"\"\<Aout\>\"", "->", "Aout"}], ",", 
           RowBox[{"\"\<Ain\>\"", "->", "Ain"}], ",", 
           RowBox[{"\"\<Residual\>\"", "->", 
            RowBox[{"fit", "[", "\"\<Residual\>\"", "]"}]}], ",", 
           RowBox[{"\"\<\[CapitalGamma]\>\"", "->", "\[CapitalGamma]1"}], ",", 
           RowBox[{
           "\"\<\[CapitalGamma]flux\>\"", "->", "\[CapitalGamma]2"}]}], 
          "|>"}]}]}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"j", ",", 
        RowBox[{"Length", "[", "\[Omega]List", "]"}]}], "}"}]}], "]"}]}], 
   "]"}]}], "\[IndentingNewLine]"}], "Input",
 CellChangeTimes->{{3.983207633474197*^9, 3.983207635420788*^9}, {
   3.9832077005835657`*^9, 3.983207743360176*^9}, {3.983207779375176*^9, 
