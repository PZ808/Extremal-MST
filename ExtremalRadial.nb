              RowBox[{"\[Lambda]", "->", "\[Lambda]val"}]}], "}"}]}], ",", 
           "yin", ",", 
           RowBox[{"{", 
            RowBox[{"R", ",", "\[Epsilon]", ",", "RouterBoundary"}], "}"}]}], 
          "]"}]}]}], "]"}]}], "]"}]}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"youtSolver", "[", 
     RowBox[{
