    RowBox[{"Block", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"M", "=", "1"}], "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{"With", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"yinval", "=", 
           RowBox[{"yinAsym", "/.", 
            RowBox[{"R", "->", "\[Epsilon]"}]}]}], ",", 
          RowBox[{"yinp", "=", 
           RowBox[{
            RowBox[{"D", "[", 
             RowBox[{"yinAsym", ",", "R"}], "]"}], "/.", 
