Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"Fext", "[", "r_", "]"}], ":=", 
   FractionBox[
    RowBox[{
     SuperscriptBox["r", "2"], "-", 
     RowBox[{"2", " ", "M", " ", "r"}], "+", 
     SuperscriptBox["M", "2"]}], 
    SuperscriptBox["r", "2"]]}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"rH", "=", 
  RowBox[{"Max", "[", 
   RowBox[{"r", "/.", 
    RowBox[{"Solve", "[", 
     RowBox[{
      RowBox[{"Fext", "[", "r", "]"}], "==", "0"}], "]"}]}], 
   "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"%", "==", "1"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"x", "[", "r_", "]"}], "=", 
    RowBox[{"Re", "[", 
     RowBox[{"Integrate", "[", 
      RowBox[{
       FractionBox[
        RowBox[{
         SuperscriptBox["r", "2"], "+", 
         SuperscriptBox["M", "2"]}], 
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           RowBox[{"Fext", "[", "r", "]"}], 
           SuperscriptBox["r", "2"]}], "//", "Simplify"}], ")"}]], ",", "r"}],
       "]"}], "]"}]}], ";"}], " "}], "\[IndentingNewLine]"}], "Input",
 CellChangeTimes->{{3.983178208486569*^9, 3.983178289405135*^9}, {
  3.983186620817855*^9, 3.983186626251343*^9}, {3.983198525439159*^9, 
  3.9831985586078987`*^9}},
 CellLabel->"In[73]:=",ExpressionUUID->"40bde018-71ae-4f3c-be7b-b6415269fab5"],

