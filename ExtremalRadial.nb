     RowBox[{"M", 
      RowBox[{"(", 
       RowBox[{"1", "+", "R"}], ")"}]}]}]}], "//", "Simplify"}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[ScriptCapitalL]", "[", "y", "]"}], "==", 
