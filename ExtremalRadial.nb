 RowBox[{
  RowBox[{
   RowBox[{"genRSols", "[", 
    RowBox[{"s_", ",", "l_", ",", "m_", ",", "\[Omega]_"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "\[Omega]hat", ",", "\[Lambda]", ",", "yinsol", ",", "youtsol", ",", 
       "\[Epsilon]", ",", "r", ",", "kLoc", ",", "yin", ",", "yout"}], "}"}], 
     ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"\[Omega]hat", "=", 
       RowBox[{
        RowBox[{"2", "M", " ", "\[Omega]"}], "-", "m"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"kLoc", "=", 
       RowBox[{"\[Omega]", "-", 
        FractionBox["m", 
         RowBox[{"2", "M"}]]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"\[Lambda]", "=", 
       RowBox[{
        RowBox[{"\[Lambda]T", "[", 
         RowBox[{"s", ",", "l", ",", "m", ",", "\[Omega]", ",", "M"}], "]"}], 
        "//", "N"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"\[Epsilon]", "=", 
       SuperscriptBox["10", 
        RowBox[{"-", "8"}]]}], ";", "\[IndentingNewLine]", 
      RowBox[{"yinsol", "=", 
       RowBox[{"yinSolver", "[", 
        RowBox[{
        "s", ",", "l", ",", "m", ",", "\[Omega]hat", ",", "\[Lambda]", ",", 
         "\[Epsilon]"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"youtsol", "=", 
       RowBox[{"youtSolver", "[", 
        RowBox[{
        "s", ",", "l", ",", "m", ",", "\[Omega]hat", ",", "\[Lambda]", ",", 
         "\[Epsilon]"}], "]"}]}], ";", "\[IndentingNewLine]", 
      "\[IndentingNewLine]", 
      RowBox[{"Rinsol", "=", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{
            SuperscriptBox[
             RowBox[{"(", 
              RowBox[{"-", "1"}], ")"}], "s"], "*", 
            SuperscriptBox[
             RowBox[{"(", 
              RowBox[{"r", "-", "M"}], ")"}], 
             RowBox[{
              RowBox[{
               RowBox[{"-", "2"}], "s"}], "-", 
              RowBox[{"2", "I", "*", "\[Omega]", "*", "M"}]}]], "*", 
            RowBox[{"Exp", "[", 
             FractionBox[
              RowBox[{"2", "I", "*", "kLoc", "*", 
               SuperscriptBox["M", "2"]}], 
              RowBox[{"r", "-", "M"}]], "]"}]}], "/.", 
           RowBox[{"r", "->", 
            RowBox[{"M", "*", 
             RowBox[{"(", 
              RowBox[{"1", "+", "R"}], ")"}]}]}]}], ")"}], "*", 
         RowBox[{"yin", "[", "R", "]"}]}], "/.", "yinsol"}]}], ";", 
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"Routsol", "=", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{
            SuperscriptBox[
             RowBox[{"(", 
              RowBox[{"r", "-", "M"}], ")"}], 
             RowBox[{"2", "I", "*", "\[Omega]", "*", "M"}]], "*", 
            RowBox[{"Exp", "[", 
             RowBox[{"-", 
              FractionBox[
               RowBox[{"2", "I", "*", "kLoc", "*", 
                SuperscriptBox["M", "2"]}], 
               RowBox[{"r", "-", "M"}]]}], "]"}]}], "/.", 
           RowBox[{"r", "->", 
            RowBox[{"M", "*", 
             RowBox[{"(", 
              RowBox[{"1", "+", "R"}], ")"}]}]}]}], ")"}], "*", 
         RowBox[{"yout", "[", "R", "]"}]}], "/.", "youtsol"}]}], ";", 
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"<|", 
       RowBox[{
        RowBox[{"\"\<s\>\"", "->", "s"}], ",", 
        RowBox[{"\"\<l\>\"", "->", "l"}], ",", 
        RowBox[{"\"\<m\>\"", "->", "m"}], ",", 
        RowBox[{"\"\<\[Omega]\>\"", "->", "\[Omega]"}], ",", 
        RowBox[{"\"\<Rin\>\"", "->", "Rinsol"}], ",", 
        RowBox[{"\"\<Rout\>\"", "->", "Routsol"}]}], "|>"}]}]}], 
    "\[IndentingNewLine]", "]"}]}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"genySols", "[", 
