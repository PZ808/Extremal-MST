Cell[BoxData[{
 RowBox[{
  RowBox[{"M", "=", "1"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"stest", "=", "2"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ltest", "=", "3"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"mtest", "=", "1"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"\[Omega]test", "=", 
    RowBox[{"N", "[", 
     RowBox[{
      FractionBox["1", 
       RowBox[{"10", "*", "M"}]], ",", "PREC"}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"Clear", "[", 
  RowBox[{"genSols", ",", "genySols"}], "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"genySols", "[", 
    RowBox[{"s_", ",", "l_", ",", "m_", ",", "\[Omega]_"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "\[Omega]hat", ",", "\[Lambda]", ",", "yinsol", ",", "youtsol", ",", 
       "\[Epsilon]", ",", "r", ",", "kLoc", ",", "yin", ",", "yout"}], "}"}], 
     ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"\[Omega]hat", "=", 
       RowBox[{
        RowBox[{"2", "M", " ", "\[Omega]"}], "-", "m"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"kLoc", "=", 
       RowBox[{"\[Omega]", "-", 
        FractionBox["m", 
         RowBox[{"2", "M"}]]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"\[Lambda]", "=", 
       RowBox[{
        RowBox[{"\[Lambda]T", "[", 
         RowBox[{"s", ",", "l", ",", "m", ",", "\[Omega]", ",", "M"}], "]"}], 
        "//", "N"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"\[Epsilon]", "=", 
       SuperscriptBox["10", 
        RowBox[{"-", "8"}]]}], ";", "\[IndentingNewLine]", 
      RowBox[{"yinsol", "=", 
       RowBox[{"yinSolver", "[", 
        RowBox[{
        "s", ",", "l", ",", "m", ",", "\[Omega]hat", ",", "\[Lambda]", ",", 
         "\[Epsilon]"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"youtsol", "=", 
       RowBox[{"youtSolver", "[", 
        RowBox[{
        "s", ",", "l", ",", "m", ",", "\[Omega]hat", ",", "\[Lambda]", ",", 
         "\[Epsilon]"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"<|", 
       RowBox[{
        RowBox[{"\"\<s\>\"", "->", "s"}], ",", 
        RowBox[{"\"\<l\>\"", "->", "l"}], ",", 
        RowBox[{"\"\<m\>\"", "->", "m"}], ",", 
        RowBox[{"\"\<\[Omega]\>\"", "->", "\[Omega]"}], ",", 
        RowBox[{"\"\<y\>\"", "->", "yinsol"}], ",", 
        RowBox[{"\"\<yp\>\"", "->", "youtsol"}]}], "|>"}]}]}], 
    "\[IndentingNewLine]", "]"}]}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"genRSols", "[", 
    RowBox[{"s_", ",", "l_", ",", "m_", ",", "\[Omega]_"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "\[Omega]hat", ",", "\[Lambda]", ",", "yinsol", ",", "youtsol", ",", 
       "\[Epsilon]", ",", "r", ",", "kLoc", ",", "Rinsol", ",", "Routsol"}], 
      "}"}], ",", 
     RowBox[{
      RowBox[{"\[Omega]hat", "=", 
       RowBox[{
        RowBox[{"2", " ", "M", " ", "\[Omega]"}], "-", "m"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"kLoc", "=", 
       RowBox[{"\[Omega]", "-", 
        RowBox[{"m", "/", 
         RowBox[{"(", 
          RowBox[{"2", " ", "M"}], ")"}]}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"\[Lambda]", "=", 
       RowBox[{
        RowBox[{"\[Lambda]T", "[", 
         RowBox[{"s", ",", "l", ",", "m", ",", "\[Omega]", ",", "M"}], "]"}], 
        "//", "N"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"\[Epsilon]", "=", 
       RowBox[{"10", "^", 
        RowBox[{"-", "8"}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"yinsol", "=", 
       RowBox[{"yinSolver", "[", 
        RowBox[{
        "s", ",", "l", ",", "m", ",", "\[Omega]hat", ",", "\[Lambda]", ",", 
         "\[Epsilon]"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"youtsol", "=", 
       RowBox[{"youtSolver", "[", 
        RowBox[{
        "s", ",", "l", ",", "m", ",", "\[Omega]hat", ",", "\[Lambda]", ",", 
         "\[Epsilon]"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"Rinsol", "=", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"(", 
              RowBox[{"-", "1"}], ")"}], "^", "s"}], "*", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"r", "-", "M"}], ")"}], "^", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{
                RowBox[{"-", "2"}], " ", "s"}], "-", 
               RowBox[{"2", " ", "I", "*", "\[Omega]", "*", "M"}]}], ")"}]}], 
            "*", 
            RowBox[{"Exp", "[", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"2", " ", "I", "*", "kLoc", "*", 
                RowBox[{"M", "^", "2"}]}], ")"}], "/", 
              RowBox[{"(", 
               RowBox[{"r", "-", "M"}], ")"}]}], "]"}]}], "/.", " ", 
           RowBox[{"r", "->", 
            RowBox[{"M", "*", 
             RowBox[{"(", 
              RowBox[{"1", "+", "R"}], ")"}]}]}]}], ")"}], "*", 
         RowBox[{"yin", "[", "R", "]"}]}], "/.", " ", "yinsol"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Routsol", "=", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"(", 
              RowBox[{"r", "-", "M"}], ")"}], "^", 
             RowBox[{"(", 
              RowBox[{"2", " ", "I", "*", "\[Omega]", "*", "M"}], ")"}]}], 
            "*", 
            RowBox[{"Exp", "[", 
             RowBox[{"-", 
              RowBox[{"(", 
               RowBox[{"2", " ", "I", "*", "kLoc", "*", 
                RowBox[{
                 RowBox[{"M", "^", "2"}], "/", 
                 RowBox[{"(", 
                  RowBox[{"r", "-", "M"}], ")"}]}]}], ")"}]}], "]"}]}], "/.", 
           " ", 
           RowBox[{"r", "->", 
            RowBox[{"M", "*", 
             RowBox[{"(", 
              RowBox[{"1", "+", "R"}], ")"}]}]}]}], ")"}], "*", 
         RowBox[{"yout", "[", "R", "]"}]}], "/.", " ", "youtsol"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"<|", 
       RowBox[{
        RowBox[{"\"\<s\>\"", "->", "s"}], ",", 
        RowBox[{"\"\<l\>\"", "->", "l"}], ",", 
        RowBox[{"\"\<m\>\"", "->", "m"}], ",", 
        RowBox[{"\"\<\[Omega]\>\"", "->", "\[Omega]"}], ",", 
        RowBox[{"\"\<Rin\>\"", "->", "Rinsol"}], ",", 
        RowBox[{"\"\<Rout\>\"", "->", "Routsol"}]}], "|>"}]}]}], "]"}]}], 
  "\[IndentingNewLine]", "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
