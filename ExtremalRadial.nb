Cell[CellGroupData[{

Cell["SN for s=0", "Section",
 CellChangeTimes->{{3.983207030714772*^9, 
  3.9832070334878674`*^9}},ExpressionUUID->"44d45842-9391-4262-ba76-\
347f37d2e452"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"ClearAll", "[", 
    RowBox[{
    "DeltaEx", ",", "KEx", ",", "lamSNScalarEx", ",", "VTScalarEx", ",", 
     "GsnScalarEx", ",", "UsnScalarEx", ",", "VeffRScalarEx", ",", "xOfREx", 
     ",", "rGuessEx", ",", "rOfXEx", ",", "VeffXScalarEx"}], "]"}], ";"}], 
  "\[IndentingNewLine]", "\n", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"extremal", " ", 
     RowBox[{"Kerr", ":", "a"}]}], "=", "M"}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"DeltaEx", "[", 
     RowBox[{"r_", ",", "M_"}], "]"}], ":=", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"r", "-", "M"}], ")"}], "^", "2"}]}], ";"}], 
  "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"KEx", "[", 
     RowBox[{"r_", ",", "M_", ",", "m_", ",", "om_"}], "]"}], ":=", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"r", "^", "2"}], "+", 
        RowBox[{"M", "^", "2"}]}], ")"}], " ", "om"}], "-", 
     RowBox[{"m", " ", "M"}]}]}], ";"}], "\[IndentingNewLine]", "\n", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
     RowBox[{"Hughes", "'"}], " ", "lambda", " ", "for", " ", "s"}], "=", 
    RowBox[{
     RowBox[{"0", ":", "lambda"}], "=", 
     RowBox[{"E_lm", "-", 
      RowBox[{"2", " ", "a", " ", "m", " ", "omega"}], "+", 
      RowBox[{
       RowBox[{"a", "^", "2"}], " ", 
       RowBox[{"omega", "^", "2"}]}]}]}]}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"lamSNScalarEx", "[", 
     RowBox[{"l_", ",", "m_", ",", "om_", ",", "M_"}], "]"}], ":=", 
    RowBox[{
     RowBox[{"SpinWeightedSpheroidalEigenvalue", "[", 
      RowBox[{"0", ",", "l", ",", "m", ",", 
       RowBox[{"M", " ", "om"}]}], "]"}], "-", 
     RowBox[{"2", " ", "M", " ", "m", " ", "om"}], "+", 
     RowBox[{
      RowBox[{"M", "^", "2"}], " ", 
      RowBox[{"om", "^", "2"}]}]}]}], ";"}], "\[IndentingNewLine]", "\n", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"Teukolsky", " ", "potential", " ", "VT", " ", "for", " ", "s"}], 
    "=", "0"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"VTScalarEx", "[", 
     RowBox[{"r_", ",", "M_", ",", "m_", ",", "om_", ",", "lam_"}], "]"}], ":=", 
    RowBox[{"lam", "-", 
     RowBox[{
      RowBox[{
       RowBox[{"KEx", "[", 
        RowBox[{"r", ",", "M", ",", "m", ",", "om"}], "]"}], "^", "2"}], "/", 
      RowBox[{"DeltaEx", "[", 
       RowBox[{"r", ",", "M"}], "]"}]}]}]}], ";"}], "\[IndentingNewLine]", 
  "\n", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"G", " ", "function", " ", "from", " ", "Hughes", " ", 
     RowBox[{"Eq", ".", 
      RowBox[{"(", "4.10", ")"}]}], " ", "with", " ", "s"}], "=", "0"}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"GsnScalarEx", "[", 
     RowBox[{"r_", ",", "M_"}], "]"}], ":=", 
    RowBox[{"r", " ", 
     RowBox[{
      RowBox[{"DeltaEx", "[", 
       RowBox[{"r", ",", "M"}], "]"}], "/", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"r", "^", "2"}], "+", 
         RowBox[{"M", "^", "2"}]}], ")"}], "^", "2"}]}]}]}], ";"}], 
  "\[IndentingNewLine]", "\n", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
     RowBox[{"Since", " ", "F1"}], "=", 
     RowBox[{
      RowBox[{"0", " ", "and", " ", "U1"}], "=", "VT"}]}], ",", 
    RowBox[{"the", " ", "scalar", " ", 
     RowBox[{"SN", "/", "GSN"}], " ", "U", " ", "is"}]}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"UsnScalarEx", "[", 
     RowBox[{"r_", ",", "M_", ",", "m_", ",", "om_", ",", "lam_"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", "rr", "}"}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{"DeltaEx", "[", 
         RowBox[{"r", ",", "M"}], "]"}], " ", 
        RowBox[{
         RowBox[{"VTScalarEx", "[", 
          RowBox[{"r", ",", "M", ",", "m", ",", "om", ",", "lam"}], "]"}], 
         "/", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"r", "^", "2"}], "+", 
            RowBox[{"M", "^", "2"}]}], ")"}], "^", "2"}]}]}], "+", 
       RowBox[{
        RowBox[{"GsnScalarEx", "[", 
         RowBox[{"r", ",", "M"}], "]"}], "^", "2"}], "+", 
       RowBox[{
        RowBox[{"DeltaEx", "[", 
         RowBox[{"r", ",", "M"}], "]"}], " ", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"D", "[", 
            RowBox[{
             RowBox[{"GsnScalarEx", "[", 
              RowBox[{"rr", ",", "M"}], "]"}], ",", "rr"}], "]"}], "/.", " ", 
           RowBox[{"rr", "->", "r"}]}], ")"}], "/", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"r", "^", "2"}], "+", 
           RowBox[{"M", "^", "2"}]}], ")"}]}]}]}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]", "\n", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"Schr\[ODoubleDot]dinger", "-", 
     RowBox[{"form", " ", "effective", " ", 
      RowBox[{"potential", ":", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"X", "''"}], "[", "x", "]"}], "+", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"om", "^", "2"}], "-", 
            RowBox[{"Veff", "[", "x", "]"}]}], ")"}], " ", 
          RowBox[{"X", "[", "x", "]"}]}]}], "==", 
        RowBox[{"0", " ", "so", " ", "Veff"}]}]}]}]}], "=", 
    RowBox[{
     RowBox[{"om", "^", "2"}], "+", "U"}]}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"VeffRScalarEx", "[", 
     RowBox[{"r_", ",", "M_", ",", "m_", ",", "om_", ",", "lam_"}], "]"}], ":=", 
    RowBox[{
     RowBox[{"om", "^", "2"}], "+", 
     RowBox[{"UsnScalarEx", "[", 
      RowBox[{"r", ",", "M", ",", "m", ",", "om", ",", "lam"}], "]"}]}]}], 
   ";"}], "\[IndentingNewLine]", "\n", 
  RowBox[{"(*", 
   RowBox[{"extremal", " ", "tortoise"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"xOfREx", "[", 
     RowBox[{"r_", ",", "M_"}], "]"}], ":=", 
    RowBox[{"r", "+", 
     RowBox[{"2", " ", "M", " ", 
      RowBox[{"Log", "[", 
       RowBox[{"r", "-", "M"}], "]"}]}], "-", 
     RowBox[{"2", " ", 
      RowBox[{
       RowBox[{"M", "^", "2"}], "/", 
       RowBox[{"(", 
        RowBox[{"r", "-", "M"}], ")"}]}]}]}]}], ";"}], "\[IndentingNewLine]", 
  "\n", 
  RowBox[{"(*", 
   RowBox[{"numerical", " ", "inverse"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"rGuessEx", "[", 
     RowBox[{
      RowBox[{"x_", "?", "NumericQ"}], ",", 
      RowBox[{"M_", "?", "NumericQ"}]}], "]"}], ":=", 
    RowBox[{"Which", "[", 
     RowBox[{
      RowBox[{"x", ">", 
       RowBox[{"10", " ", "M"}]}], ",", "x", ",", 
      RowBox[{"x", ">", "0"}], ",", 
      RowBox[{"M", "+", "x", "+", "1"}], ",", "True", ",", 
      RowBox[{"M", "+", 
       RowBox[{"Max", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"10.", "^", 
           RowBox[{"-", "12"}]}], " ", "M"}], ",", 
         RowBox[{"2", " ", 
          RowBox[{
           RowBox[{"M", "^", "2"}], "/", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"-", "x"}], "+", "1"}], ")"}]}]}]}], "]"}]}]}], "]"}]}], 
   ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"rOfXEx", "[", 
     RowBox[{
      RowBox[{"x_", "?", "NumericQ"}], ",", 
      RowBox[{"M_", "?", "NumericQ"}]}], "]"}], ":=", 
    RowBox[{"r", "/.", " ", 
     RowBox[{"FindRoot", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"xOfREx", "[", 
         RowBox[{"r", ",", "M"}], "]"}], "==", "x"}], ",", 
       RowBox[{"{", 
        RowBox[{"r", ",", 
         RowBox[{"rGuessEx", "[", 
          RowBox[{"x", ",", "M"}], "]"}]}], "}"}], ",", 
       RowBox[{"WorkingPrecision", "->", "40"}], ",", 
       RowBox[{"AccuracyGoal", "->", "20"}], ",", 
       RowBox[{"PrecisionGoal", "->", "20"}]}], "]"}]}]}], ";"}], 
  "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"VeffXScalarEx", "[", 
    RowBox[{
     RowBox[{"x_", "?", "NumericQ"}], ",", 
     RowBox[{"M_", "?", "NumericQ"}], ",", "m_Integer", ",", 
     RowBox[{"om_", "?", "NumericQ"}], ",", "lam_"}], "]"}], ":=", 
   RowBox[{"VeffRScalarEx", "[", 
    RowBox[{
     RowBox[{"rOfXEx", "[", 
      RowBox[{"x", ",", "M"}], "]"}], ",", "M", ",", "m", ",", "om", ",", 
     "lam"}], "]"}]}], ";"}]}], "Input",
