Cell[BoxData[
 RowBox[{"\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"ClearAll", "[", 
     RowBox[{"fitFarWaveSNExtremal", ",", "genGBspinM2"}], "]"}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"fitFarWaveSNExtremal", "[", 
     RowBox[{"Zfun_", ",", 
      RowBox[{"\[Omega]_", "?", "NumericQ"}], ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"x1_", "?", "NumericQ"}], ",", 
        RowBox[{"x2_", "?", "NumericQ"}]}], "}"}], ",", 
      RowBox[{"n_Integer", ":", "400"}]}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "xData", ",", "yData", ",", "mat", ",", "coeffs", ",", "resid"}], 
       "}"}], ",", 
      RowBox[{
       RowBox[{"xData", "=", 
        RowBox[{"Subdivide", "[", 
         RowBox[{"x1", ",", "x2", ",", "n"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"yData", "=", 
        RowBox[{"Zfun", "/@", "xData"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"mat", "=", 
        RowBox[{"Transpose", "@", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"Exp", "[", 
            RowBox[{"I", " ", "\[Omega]", " ", "xData"}], "]"}], ",", 
           RowBox[{"Exp", "[", 
            RowBox[{
             RowBox[{"-", "I"}], " ", "\[Omega]", " ", "xData"}], "]"}]}], 
          "}"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"coeffs", "=", 
        RowBox[{"LeastSquares", "[", 
         RowBox[{"mat", ",", "yData"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"resid", "=", 
        RowBox[{
         RowBox[{"Norm", "[", 
          RowBox[{
           RowBox[{"mat", ".", "coeffs"}], "-", "yData"}], "]"}], "/", 
         RowBox[{"Norm", "[", "yData", "]"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"<|", 
        RowBox[{
         RowBox[{"\"\<Aout\>\"", "->", 
          RowBox[{"coeffs", "[", 
           RowBox[{"[", "1", "]"}], "]"}]}], ",", 
         RowBox[{"\"\<Ain\>\"", "->", 
          RowBox[{"coeffs", "[", 
           RowBox[{"[", "2", "]"}], "]"}]}], ",", 
         RowBox[{"\"\<Residual\>\"", "->", "resid"}], ",", 
         RowBox[{"\"\<xData\>\"", "->", "xData"}], ",", 
         RowBox[{"\"\<yData\>\"", "->", "yData"}]}], "|>"}]}]}], "]"}]}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"genGBspinM2", "[", 
     RowBox[{
     "\[Omega]List_", ",", "l_", ",", "m_", ",", "xmin_", ",", "xmax_", ",", 
      RowBox[{"fitWidth_", ":", "100"}], ",", 
      RowBox[{"nFit_Integer", ":", "400"}]}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", "kH", "}"}], ",", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"Module", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
           "\[Omega]", ",", "Zfun", ",", "fit", ",", "x1", ",", "x2"}], "}"}],
           ",", 
          RowBox[{
           RowBox[{"\[Omega]", "=", 
            RowBox[{"\[Omega]List", "[", 
             RowBox[{"[", "j", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
           RowBox[{"kH", "=", 
            RowBox[{"\[Omega]", "-", 
             RowBox[{"m", "/", 
              RowBox[{"(", 
               RowBox[{"2", " ", "M"}], ")"}]}]}]}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"Zfun", "=", 
            RowBox[{"NDSolveValue", "[", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{
                RowBox[{
                 RowBox[{
                  RowBox[{
                   RowBox[{"Z", "''"}], "[", "x", "]"}], "+", 
                  RowBox[{
                   RowBox[{"(", 
                    RowBox[{
                    RowBox[{"\[Omega]", "^", "2"}], "-", 
                    RowBox[{
                    RowBox[{"VeffInter", "[", 
                    RowBox[{"\[Omega]", ",", "m", ",", "l"}], "]"}], "[", "x",
                     "]"}]}], ")"}], " ", 
                   RowBox[{"Z", "[", "x", "]"}]}]}], "==", "0"}], ",", 
                RowBox[{"(*", 
                 RowBox[{"likely", " ", "horizon", " ", "condition"}], "*)"}], 
                RowBox[{
                 RowBox[{"Z", "[", "xmin", "]"}], "==", 
                 RowBox[{"Exp", "[", 
                  RowBox[{
                   RowBox[{"-", "I"}], " ", "kH", " ", "xmin"}], "]"}]}], ",", 
                RowBox[{
                 RowBox[{
                  RowBox[{"Z", "'"}], "[", "xmin", "]"}], "==", 
                 RowBox[{
                  RowBox[{"-", "I"}], " ", "kH", " ", 
                  RowBox[{"Exp", "[", 
                   RowBox[{
                    RowBox[{"-", "I"}], " ", "kH", " ", "xmin"}], "]"}]}]}]}],
                "}"}], ",", "Z", ",", 
              RowBox[{"{", 
               RowBox[{"x", ",", "xmin", ",", "xmax"}], "}"}]}], "]"}]}], ";",
            "\[IndentingNewLine]", 
           RowBox[{"x1", "=", 
            RowBox[{"xmax", "-", "fitWidth"}]}], ";", "\[IndentingNewLine]", 
           RowBox[{"x2", "=", "xmax"}], ";", "\[IndentingNewLine]", 
           RowBox[{"fit", "=", 
            RowBox[{"fitFarWaveSNExtremal", "[", 
             RowBox[{"Zfun", ",", "\[Omega]", ",", 
              RowBox[{"{", 
               RowBox[{"x1", ",", "x2"}], "}"}], ",", "nFit"}], "]"}]}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"<|", 
            RowBox[{
             RowBox[{"\"\<\[Omega]\>\"", "->", "\[Omega]"}], ",", 
             RowBox[{"\"\<Aout\>\"", "->", 
              RowBox[{"fit", "[", "\"\<Aout\>\"", "]"}]}], ",", 
             RowBox[{"\"\<Ain\>\"", "->", 
              RowBox[{"fit", "[", "\"\<Ain\>\"", "]"}]}], ",", 
             RowBox[{"\"\<Residual\>\"", "->", 
              RowBox[{"fit", "[", "\"\<Residual\>\"", "]"}]}], ",", 
             RowBox[{"\"\<\[CapitalGamma]\>\"", "->", 
              RowBox[{"GBfromAinSNExtremal", "[", 
               RowBox[{"fit", "[", "\"\<Ain\>\"", "]"}], "]"}]}]}], 
            "|>"}]}]}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"j", ",", 
          RowBox[{"Length", "[", "\[Omega]List", "]"}]}], "}"}]}], "]"}]}], 
     "]"}]}], "\[IndentingNewLine]"}]}]], "Input",
 CellChangeTimes->{{3.983198940882256*^9, 3.983198951096518*^9}, 
   3.983199124320491*^9, {3.983199172011693*^9, 3.983199211359288*^9}, {
