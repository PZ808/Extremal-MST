Cell[BoxData[
 RowBox[{
  RowBox[{"ClearAll", "[", 
   RowBox[{
   "rPlus", ",", "OmegaH", ",", "kH", ",", "epsH", ",", "CStarSq", ",", "dSN",
     ",", "alphaGW", ",", "GBfromAinSN"}], "]"}], ";"}]], "Input",
 CellChangeTimes->{{3.983195042736492*^9, 3.983195044842808*^9}},
 CellLabel->"In[37]:=",ExpressionUUID->"66e2b4ef-ca81-4d1e-88db-c5066340b4b3"],

Cell[CellGroupData[{

Cell["spin=-2 conversion from amplitude to GB factor", "Subsection",
 CellChangeTimes->{{3.983195410911377*^9, 
  3.983195424565383*^9}},ExpressionUUID->"0acffd57-2dd6-4a32-b8df-\
61e29cac0426"],

Cell[BoxData[
 RowBox[{"\[IndentingNewLine]", "\[IndentingNewLine]", "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"|", 
     RowBox[{"C_", 
      RowBox[{"{", "lm\[Omega]", "}"}]}], "|", 
     RowBox[{"^", "2"}]}], ",", 
    RowBox[{
     RowBox[{
      RowBox[{"i", ".", "e", ".", "the"}], " ", "squared", " ", 
      "Starobinsky"}], "-", 
     RowBox[{"Churilov", " ", "constant"}]}]}], " ", "\[IndentingNewLine]", 
   "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"CStarSq", "[", 
      RowBox[{
      "\[Lambda]_", ",", "\[Omega]_", ",", "m_", ",", "a_", ",", "M_"}], 
      "]"}], ":=", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"\[Lambda]", "+", "2"}], ")"}], "^", "2"}], "+", 
         RowBox[{"4", " ", "a", " ", "\[Omega]", " ", "m"}], "-", 
         RowBox[{"4", " ", 
          RowBox[{"a", "^", "2"}], " ", 
          RowBox[{"\[Omega]", "^", "2"}]}]}], ")"}], "*", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"\[Lambda]", "^", "2"}], "+", 
         RowBox[{"36", " ", "a", " ", "\[Omega]", " ", "m"}], "-", 
         RowBox[{"36", " ", 
          RowBox[{"a", "^", "2"}], " ", 
          RowBox[{"\[Omega]", "^", "2"}]}]}], ")"}]}], "+", 
      RowBox[{"48", " ", "a", " ", "\[Omega]", " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"2", " ", "\[Lambda]"}], "+", "3"}], ")"}], " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"2", " ", "a", " ", "\[Omega]"}], "-", "m"}], ")"}]}], "+", 
      RowBox[{"144", " ", 
       RowBox[{"\[Omega]", "^", "2"}], " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"M", "^", "2"}], "-", 
         RowBox[{"a", "^", "2"}]}], ")"}]}]}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"horizon", "-", 
     RowBox[{"flux", " ", "prefactor", " ", "\[Alpha]_", 
      RowBox[{"{", "lm\[Omega]", "}"}]}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"alphaGW", "[", 
      RowBox[{
      "\[Lambda]_", ",", "\[Omega]_", ",", "m_", ",", "a_", ",", "M_"}], 
      "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"rp", "=", 
          RowBox[{"rPlus", "[", 
           RowBox[{"a", ",", "M"}], "]"}]}], ",", 
         RowBox[{"k", "=", 
          RowBox[{"kH", "[", 
           RowBox[{"\[Omega]", ",", "m", ",", "a", ",", "M"}], "]"}]}], ",", 
         RowBox[{"eps", "=", 
          RowBox[{"epsH", "[", 
           RowBox[{"a", ",", "M"}], "]"}]}]}], "}"}], ",", 
       RowBox[{"256", " ", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"2", " ", "M", " ", "rp"}], ")"}], "^", "5"}], " ", "k", 
        " ", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"k", "^", "2"}], "+", 
          RowBox[{"4", " ", 
           RowBox[{"eps", "^", "2"}]}]}], ")"}], " ", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"k", "^", "2"}], "+", 
          RowBox[{"16", " ", 
           RowBox[{"eps", "^", "2"}]}]}], ")"}], " ", 
        RowBox[{
         RowBox[{"\[Omega]", "^", "3"}], "/", 
         RowBox[{"CStarSq", "[", 
          RowBox[{
          "\[Lambda]", ",", "\[Omega]", ",", "m", ",", "a", ",", "M"}], 
          "]"}]}]}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
     "Greybody", " ", "factor", " ", "from", " ", "the", " ", "fitted", " ", 
      "SN", " ", "incoming", " ", "amplitude", " ", "at", " ", 
      RowBox[{"infinity", ".", "Assumes"}], " ", "the", " ", "SN", " ", 
      "solution", " ", "is", " ", "normalized", " ", "as", " ", 
      RowBox[{"X", "~", 
       RowBox[{"exp", "[", 
        RowBox[{
         RowBox[{"-", "I"}], " ", "k", " ", "r", "*"}], "]"}]}], " ", "at", 
      " ", "the", " ", "horizon"}], ",", 
     RowBox[{
      RowBox[{"i", ".", "e", ".", "AtransSN"}], "=", "1."}]}], "*)"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"GBfromAmplitudeSN", "[", 
     RowBox[{
     "AinSN_", ",", "\[Lambda]_", ",", "\[Omega]_", ",", "m_", ",", "a_", ",",
       "M_"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "rp", ",", "kH", ",", "OmH", ",", " ", "epsH", ",", "C2", ",", "dSN", 
        ",", "\[Alpha]GW", ",", "conversion"}], "}"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"rp", "=", 
        RowBox[{"M", "+", 
         RowBox[{"Sqrt", "[", 
          RowBox[{
           RowBox[{"M", "^", "2"}], "-", 
           RowBox[{"a", "^", "2"}]}], "]"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"OmH", ":=", 
        RowBox[{"a", "/", 
         RowBox[{"(", 
          RowBox[{"2", " ", "M", " ", "rp"}], ")"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"kH", "-", 
        RowBox[{"m", " ", "OmH"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"epsH", "=", 
        RowBox[{
         RowBox[{"Sqrt", "[", 
          RowBox[{
           RowBox[{"M", "^", "2"}], "-", 
           RowBox[{"a", "^", "2"}]}], "]"}], "/", 
         RowBox[{"(", 
          RowBox[{"4", " ", "M", " ", "rp"}], ")"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"C2", "=", 
        RowBox[{"CStarSq", "[", 
         RowBox[{"\[Lambda]", ",", "\[Omega]", ",", "m", ",", "a", ",", "M"}],
          "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
         RowBox[{"d_", 
          RowBox[{"{", "lm\[Omega]", "}"}]}], "=", 
         RowBox[{"\[CapitalGamma]_", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"H", ",", "-"}], "}"}], "^", 
           RowBox[{"{", 
            RowBox[{"-", "1"}], "}"}]}]}]}], "*)"}], "\[IndentingNewLine]", 
       RowBox[{"dSN", "=", 
        RowBox[{"8", " ", 
         RowBox[{"Sqrt", "[", 
          RowBox[{"2", " ", "M", " ", "rp"}], "]"}], " ", 
         RowBox[{"(", 
          RowBox[{"rp", "-", "M", "-", 
           RowBox[{"2", " ", "I", " ", "k", " ", "M", " ", "rp"}]}], ")"}], 
         " ", 
         RowBox[{"(", 
          RowBox[{"rp", "-", "M", "-", 
           RowBox[{"I", " ", "k", " ", "M", " ", "rp"}]}], ")"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"\[Alpha]GW", "=", 
        RowBox[{"alphaGW", "[", 
         RowBox[{"\[Lambda]", ",", "\[Omega]", ",", "m", ",", "a", ",", "M"}],
          "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"conversion", "=", 
        RowBox[{"\[Alpha]GW", "*", 
         RowBox[{
          RowBox[{"Abs", "[", 
           RowBox[{"4", " ", 
            RowBox[{
             RowBox[{"\[Omega]", "^", "2"}], "/", 
             RowBox[{"(", 
