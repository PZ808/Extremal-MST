  RowBox[{
   RowBox[{
    RowBox[{"nbrr", "=", "1000"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"tr", "=", 
     RowBox[{"N", "[", 
      RowBox[{"rH", 
       RowBox[{"(", 
        RowBox[{"1", "+", 
         RowBox[{"10", "^", 
          RowBox[{"Range", "[", 
           RowBox[{
            RowBox[{"-", "11"}], ",", 
            RowBox[{"-", "1"}], ",", 
            RowBox[{"(", 
             RowBox[{"10", "/", 
              RowBox[{"(", 
               RowBox[{"nbrr", "-", "1"}], ")"}]}], ")"}]}], "]"}]}]}], 
        ")"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"For", "[", 
     RowBox[{
      RowBox[{"i", "=", "1"}], ",", 
      RowBox[{"i", "<", "nbrr"}], ",", 
      RowBox[{"i", "++"}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{"X", "[", "i", "]"}], "=", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"x", "[", 
           RowBox[{"tr", "[", 
            RowBox[{"[", "i", "]"}], "]"}], "]"}], ",", 
          RowBox[{"tr", "[", 
           RowBox[{"[", "i", "]"}], "]"}]}], "}"}]}], ";"}]}], "]"}], ";"}], 
   "\n", 
   RowBox[{
    RowBox[{"X1", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"X", "[", 
        RowBox[{"nbrr", "-", "i"}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "1", ",", 
         RowBox[{"nbrr", "-", "2"}]}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"FH", " ", "sampling"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{"For", "[", 
    RowBox[{
     RowBox[{"i", "=", "2"}], ",", 
     RowBox[{"i", "<", "5000"}], ",", 
     RowBox[{"i", "++"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"X", "[", "i", "]"}], "=", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"x", "[", 
          RowBox[{"rH", 
           RowBox[{"(", 
            RowBox[{"1", "+", 
             RowBox[{"0.1", "i"}]}], ")"}]}], "]"}], ",", 
         RowBox[{"rH", 
          RowBox[{"(", 
           RowBox[{"1", "+", 
            RowBox[{"0.1", "i"}]}], ")"}]}]}], "}"}]}], ";"}]}], 
    "\[IndentingNewLine]", "]"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"X2", "=", 
     RowBox[{"Table", " ", "[", 
      RowBox[{
       RowBox[{"X", "[", "i", "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "2", ",", "4999"}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"Veff", "[", "x_", "]"}], ":=", " ", 
     RowBox[{"(*", 
      RowBox[{"Add", " ", "code", " ", "here"}], " ", "*)"}], 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"\[Omega]j", "=", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"0.01", " ", "j"}], " ", ",", 
        RowBox[{"{", 
         RowBox[{"j", ",", "1", ",", "100"}], "}"}]}], "]"}]}]}], ";"}], 
   RowBox[{"(*", 
    RowBox[{
    "Table", " ", "of", " ", "energies", " ", "where", " ", "to", " ", 
     "evaluete", " ", "the", " ", "GBF"}], "*)"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Generating", " ", "the", " ", "GB", " ", "factors"}], " ", 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"genGBspinM2", "[", 
     RowBox[{
     "Veff_", ",", "\[Omega]j_", ",", "xmin\[Infinity]_", ",", 
      "xmax\[Infinity]_"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "Z", ",", "schrodingerEq", ",", "j", ",", "\[Omega]", ",", 
        "boundaryConditions", ",", "sol", ",", "xfar", ",", "FF", ",", "NLM", 
        ",", "\[ScriptA]", ",", "\[ScriptB]", ",", "p", ",", "i", ",", "T", 
        ",", "\[CapitalGamma]"}], "}"}], ",", "\[IndentingNewLine]", "\t", 
      RowBox[{"For", "[", 
       RowBox[{
        RowBox[{"j", "=", "1"}], ",", 
        RowBox[{"j", "<=", 
         RowBox[{"Length", "[", "\[Omega]j", "]"}]}], ",", 
        RowBox[{"j", "++"}], ",", "\t", "\[IndentingNewLine]", 
        "\[IndentingNewLine]", "\t", "\[IndentingNewLine]", "\t\t", 
        RowBox[{
         RowBox[{"\[Omega]", "=", 
          RowBox[{"\[Omega]j", "[", 
           RowBox[{"[", "j", "]"}], "]"}]}], ";", " ", 
         RowBox[{"(*", 
          RowBox[{
          "Frequency", " ", "of", " ", "the", " ", "incoming", " ", "wave"}], 
          "*)"}], "\[IndentingNewLine]", "\[IndentingNewLine]", "\t\t", 
         RowBox[{"(*", 
          RowBox[{
           RowBox[{"Define", " ", "the", " ", "Schr\[ODoubleDot]dinger"}], 
           "-", 
           RowBox[{"like", " ", "equation"}]}], "*)"}], "\[IndentingNewLine]",
          "\t\t", 
         RowBox[{"schrodingerEq", "=", 
          RowBox[{
           RowBox[{
            RowBox[{"D", "[", 
             RowBox[{
              RowBox[{"Z", "[", "x", "]"}], ",", 
              RowBox[{"{", 
               RowBox[{"x", ",", "2"}], "}"}]}], "]"}], "+", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{
               SuperscriptBox["\[Omega]", "2"], "-", 
               RowBox[{"Veff", "[", "x", "]"}]}], ")"}], " ", 
             RowBox[{"Z", "[", "x", "]"}]}]}], "==", "0"}]}], ";", 
         "\[IndentingNewLine]", "\[IndentingNewLine]", "\t\t", 
         RowBox[{"(*", 
          RowBox[{
          "Boundary", " ", "conditions", " ", "for", " ", "the", " ", 
           "wavefunction", " ", "near", " ", "the", " ", "horizon"}], "*)"}], 
         "\[IndentingNewLine]", "\t\t", 
         RowBox[{"boundaryConditions", "=", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{
             RowBox[{"Z", "[", "xmin\[Infinity]", "]"}], "==", 
             RowBox[{"Exp", "[", 
              RowBox[{
               RowBox[{"-", "I"}], " ", "\[Omega]", " ", 
               RowBox[{"(", "xmin\[Infinity]", ")"}]}], "]"}]}], ",", 
            RowBox[{
             RowBox[{
              RowBox[{"Z", "'"}], "[", "xmin\[Infinity]", "]"}], "==", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{
                RowBox[{"-", "I"}], " ", "\[Omega]"}], ")"}], 
              RowBox[{"Exp", "[", 
               RowBox[{
                RowBox[{"-", "I"}], " ", "\[Omega]", " ", 
                RowBox[{"(", "xmin\[Infinity]", ")"}]}], "]"}]}]}]}], "}"}]}],
          ";", "\[IndentingNewLine]", "\n", "\t\t", 
         RowBox[{"(*", 
          RowBox[{"Solve", " ", "the", " ", "equation", " ", "numerically"}], 
          "*)"}], "\[IndentingNewLine]", "\t\t", 
         RowBox[{"sol", "=", 
          RowBox[{"NDSolve", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"schrodingerEq", ",", "boundaryConditions"}], "}"}], ",",
             "Z", ",", 
            RowBox[{"{", 
             RowBox[{"x", ",", "xmin\[Infinity]", ",", "xmax\[Infinity]"}], 
             "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", "\t", 
         "\[IndentingNewLine]", "\[IndentingNewLine]", "\t\t\t\t\t", 
         RowBox[{"(*", 
          RowBox[{
          "Far", " ", "horizon", " ", "region", " ", "reconstruction", " ", 
           RowBox[{"(", 
            RowBox[{"integration", " ", "out"}], ")"}]}], "*)"}], 
         "\[IndentingNewLine]", "\[IndentingNewLine]", "\t\t\t\t\t", 
         RowBox[{"xfar", "=", 
          RowBox[{"IntegerPart", "[", 
           RowBox[{"xmax\[Infinity]", "/", "4"}], "]"}]}], ";", 
         RowBox[{"(*", 
          RowBox[{
           RowBox[{
           "Distance", " ", "from", " ", "xmax\[Infinity]", " ", "such", " ", 
            "that", " ", "xmax\[Infinity]"}], "-", 
           RowBox[{
           "xfar", " ", "is", " ", "still", " ", "in", " ", "the", " ", "far",
             " ", "region"}]}], "*)"}], "\[IndentingNewLine]", 
         "\[IndentingNewLine]", "\t\t\t\t\t", 
         RowBox[{"(*", 
          RowBox[{
          "Sampling", " ", "in", " ", "the", " ", "far", " ", "horizon", " ", 
           "region"}], "*)"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
         "\t\t\t\t\t\t\t", 
         RowBox[{"For", "[", "\[IndentingNewLine]", "\t\t\t\t\t\t\t\t", 
          RowBox[{
           RowBox[{"i", "=", "0"}], ",", 
           RowBox[{"i", "<=", "xfar"}], ",", 
           RowBox[{"i", "++"}], ",", "\[IndentingNewLine]", 
           "\t\t\t\t\t\t\t\t", 
           RowBox[{
            RowBox[{"p", "[", "i", "]"}], "=", 
            RowBox[{
             RowBox[{"Z", "[", 
              RowBox[{"xmax\[Infinity]", "-", "xfar", "+", "i"}], "]"}], "/.",
              " ", "sol"}]}]}], "\[IndentingNewLine]", "\t\t", 
          "\[IndentingNewLine]", "\t\t\t\t\t\t\t\t", "]"}], ";", 
         "\[IndentingNewLine]", "\[IndentingNewLine]", "\t\t\t\t\t", 
         RowBox[{"FF", "=", 
          RowBox[{"Flatten", "[", 
           RowBox[{"Table", "[", 
            RowBox[{
             RowBox[{"p", "[", "i", "]"}], ",", 
             RowBox[{"{", 
              RowBox[{"i", ",", "0", ",", "xfar"}], "}"}]}], "]"}], "]"}]}], 
         ";", 
         RowBox[{"(*", 
          RowBox[{
          "Table", " ", "of", " ", "values", " ", "of", " ", "the", " ", 
           "solution"}], "*)"}], "\[IndentingNewLine]", "\t\t\t\t\t", 
         RowBox[{"NLM", "=", 
          RowBox[{"NonlinearModelFit", "[", 
           RowBox[{"FF", ",", 
            RowBox[{
             RowBox[{"\[ScriptA]", " ", 
              RowBox[{"Exp", "[", 
               RowBox[{"I", " ", "\[Omega]", " ", "x"}], "]"}]}], "+", 
             RowBox[{"\[ScriptB]", " ", 
              RowBox[{"Exp", "[", 
               RowBox[{
                RowBox[{"-", " ", "I"}], " ", "\[Omega]", " ", "x"}], 
               "]"}]}]}], ",", 
            RowBox[{"{", 
             RowBox[{"\[ScriptA]", ",", "\[ScriptB]"}], "}"}], ",", "x"}], 
           "]"}]}], ";", " ", 
         RowBox[{"(*", 
          RowBox[{"Fit", " ", "of", " ", "the", " ", "solution"}], " ", 
          "*)"}], "\[IndentingNewLine]", "\t\t\t\t\t", 
         RowBox[{
          RowBox[{"T", "[", "j", "]"}], "=", 
          RowBox[{
           RowBox[{
            RowBox[{"1", "/", 
             SuperscriptBox[
              RowBox[{"(", 
               RowBox[{"Abs", "[", 
                RowBox[{"\[ScriptB]", " ", "/.", 
                 RowBox[{"NLM", "[", "\"\<BestFitParameters\>\"", "]"}]}], 
                "]"}], ")"}], "2"]}], 
            RowBox[{"(*", 
             RowBox[{"GBF", " ", "value", " ", "at", " ", "\[Omega]j"}], 
             "*)"}], "\[IndentingNewLine]", "\t\t\t\t", "\[CapitalGamma]"}], 
           "=", 
           RowBox[{"Table", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{
               RowBox[{"\[Omega]j", "[", 
                RowBox[{"[", " ", "j", "]"}], "]"}], ",", 
               RowBox[{"T", "[", "j", "]"}]}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"j", ",", "1", ",", 
               RowBox[{"Length", "[", "\[Omega]j", "]"}]}], "}"}]}], 
            "]"}]}]}]}]}], " ", 
       RowBox[{"(*", 
        RowBox[{"GBF", " ", "table"}], "*)"}], "\[IndentingNewLine]", 
       "\t\t\t", "]"}]}], "\[IndentingNewLine]", "]"}]}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", "\[IndentingNewLine]", 
   "\[IndentingNewLine]", "\[IndentingNewLine]"}]}]], "Input",
 CellChangeTimes->{{3.983177887191235*^9, 3.983177896715423*^9}, {
