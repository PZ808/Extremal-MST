 RowBox[{
  RowBox[{"ClearAll", "[", 
   RowBox[{
   "SpinWeightedSpheroidalEigenvalue", ",", 
    "SpinWeightedSpheroidalEigenvector", ",", 
    "SpinWeightedSpheroidalHarmonic"}], "]"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"SpinWeightedSpheroidalEigenvalue", "[", 
     RowBox[{"s_", ",", "l_", ",", "m_", ",", "x_"}], "]"}], ":=", 
    RowBox[{
     RowBox[{"SpinWeightedSpheroidalEigenvalue", "[", 
      RowBox[{"s", ",", "l", ",", "m", ",", "x"}], "]"}], "=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"kmax", "=", "50"}], ",", 
         RowBox[{"M", "=", "m"}], ",", "lmin", ",", "Nmax", ",", "TheMatrix", 
         ",", "EigenVals", ",", "i", ",", "EigenValPosition", ",", 
         "TrueEigenValue"}], "}"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"lmin", "=", 
         RowBox[{"Max", "[", 
          RowBox[{
           RowBox[{"Abs", "[", "s", "]"}], ",", 
           RowBox[{"Abs", "[", "m", "]"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"Nmax", "=", 
         RowBox[{"l", "+", "kmax", "+", "M", "+", 
          RowBox[{"10", "*", 
           RowBox[{"Ceiling", "[", 
            RowBox[{"Log", "[", 
             RowBox[{
              RowBox[{"Abs", "[", "x", "]"}], "+", "1"}], "]"}], "]"}]}]}]}], 
        ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"TheMatrix", "=", 
         RowBox[{"Drop", "[", 
          RowBox[{
           RowBox[{"SparseArray", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{
               RowBox[{
                RowBox[{"{", 
                 RowBox[{"i_", ",", "i_"}], "}"}], "\[Rule]", 
                RowBox[{"k1", "[", 
                 RowBox[{"s", ",", 
                  RowBox[{"lmin", "+", "i", "-", "1"}], ",", "M", ",", "x"}], 
                 "]"}]}], ",", 
               RowBox[{
                RowBox[{
                 RowBox[{"{", 
                  RowBox[{"i_", ",", "j_"}], "}"}], "/;", 
                 RowBox[{
                  RowBox[{"j", "-", "i"}], "\[Equal]", "1"}]}], "\[Rule]", 
                RowBox[{"kTilde1", "[", 
                 RowBox[{"s", ",", 
                  RowBox[{"lmin", "+", "i", "-", "1"}], ",", "M", ",", "x"}], 
                 "]"}]}], ",", 
               RowBox[{
                RowBox[{
                 RowBox[{"{", 
                  RowBox[{"i_", ",", "j_"}], "}"}], "/;", 
                 RowBox[{
                  RowBox[{"j", "-", "i"}], "\[Equal]", "2"}]}], "\[Rule]", 
                RowBox[{"kHat", "[", 
                 RowBox[{"s", ",", 
                  RowBox[{"lmin", "+", "i", "-", "1"}], ",", "M", ",", "x"}], 
                 "]"}]}], ",", 
               RowBox[{
                RowBox[{
                 RowBox[{"{", 
                  RowBox[{"i_", ",", "j_"}], "}"}], "/;", 
                 RowBox[{
                  RowBox[{"j", "-", "i"}], "\[Equal]", "3"}]}], "\[Rule]", 
                RowBox[{"kTilde2", "[", 
                 RowBox[{"s", ",", 
                  RowBox[{"lmin", "+", "i", "-", "1"}], ",", "M", ",", "x"}], 
                 "]"}]}], ",", 
               RowBox[{
                RowBox[{
                 RowBox[{"{", 
                  RowBox[{"i_", ",", "j_"}], "}"}], "/;", 
                 RowBox[{
                  RowBox[{"j", "-", "i"}], "\[Equal]", "4"}]}], "\[Rule]", 
                RowBox[{"k2", "[", 
                 RowBox[{"s", ",", 
                  RowBox[{"lmin", "+", "i", "-", "1"}], ",", "M", ",", "x"}], 
                 "]"}]}]}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"Nmax", ",", "Nmax"}], "}"}]}], "]"}], ",", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"Nmax", "-", "1"}], ",", "Nmax"}], "}"}], ",", "2"}], 
          "]"}]}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"EigenVals", "=", 
         RowBox[{"Re", "[", 
          RowBox[{"Eigenvalues", "[", 
           RowBox[{"Normal", "[", "TheMatrix", "]"}], "]"}], "]"}]}], ";", 
        " ", "\[IndentingNewLine]", 
        RowBox[{"EigenValPosition", "=", 
         RowBox[{
          RowBox[{"Ordering", "[", 
           RowBox[{"EigenVals", ",", 
            RowBox[{"{", 
             RowBox[{"l", "-", "lmin", "+", "1"}], "}"}], ",", "Greater"}], 
           "]"}], "[", 
          RowBox[{"[", "1", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
        "\[IndentingNewLine]", 
        RowBox[{"TrueEigenValue", "=", 
         RowBox[{"-", 
          RowBox[{"EigenVals", "[", 
           RowBox[{"[", "EigenValPosition", "]"}], "]"}]}]}]}]}], 
      "\[IndentingNewLine]", "]"}]}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
