           RowBox[{"def", "=", 
            RowBox[{"centralDefectAtNu", "[", 
             RowBox[{"nu", ",", "params0", ",", 
              RowBox[{"WorkingPrecision", "->", "wp"}], ",", 
              RowBox[{"Cutoff", "->", 
