    RowBox[{"Association", "@", 
     RowBox[{"KeyValueMap", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"#1", "->", 
         RowBox[{"toWP", "[", 
          RowBox[{"#2", ",", "wp"}], "]"}]}], "&"}], ",", "assoc"}], 
      "]"}]}]}], ";"}], "\n", "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"mode", " ", "data"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Mval", "=", 
   RowBox[{"SetPrecision", "[", 
    RowBox[{
     RowBox[{"1", "/", "2"}], ",", "wp"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"aval", "=", "Mval"}], ";"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{"sval", "=", "2"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"lval", "=", "2"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"mval", "=", "2"}], ";"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"\[Omega]$hat", "=", 
    RowBox[{"SetPrecision", "[", 
     RowBox[{
      RowBox[{"41", "/", "50"}], ",", "wp"}], "]"}]}], ";"}], "   ", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"=", "0.82"}], ",", 
    RowBox[{"this", " ", "is", " ", "2", " ", "M", " ", "\[Omega]"}]}], 
   "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"\[Omega]Phys", "=", 
    RowBox[{"SetPrecision", "[", 
     RowBox[{
      RowBox[{"\[Omega]$hat", "/", 
       RowBox[{"(", 
        RowBox[{"2", " ", "Mval"}], ")"}]}], ",", "wp"}], "]"}]}], ";"}], 
  "\n", "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"monodromy", " ", "seed", " ", "only"}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"nuSeed", "=", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"NewMonodromyNoGammas", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
          "sval", ",", "lval", ",", "mval", ",", "\[Omega]Phys", ",", "Mval", 
           ",", "aval"}], "}"}], ",", "256"}], "]"}], "[", 
       RowBox[{"[", "1", "]"}], "]"}], " ", "I"}], "+", "lval"}]}], ";"}], 
  "\n", "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"build", " ", "params", " ", "without", " ", "nu", " ", "first"}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"paramsBase", "=", 
    RowBox[{"makeExtremalMSTParams", "[", 
     RowBox[{
     "Mval", ",", "\[Omega]Phys", ",", "sval", ",", "lval", ",", "mval", ",", 
      
      RowBox[{"Missing", "[", "\"\<A\>\"", "]"}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"Asep", "=", 
    RowBox[{"SetPrecision", "[", 
     RowBox[{
      RowBox[{"SpinWeightedSpheroidalEigenvalue", "[", 
       RowBox[{"sval", ",", "lval", ",", "mval", ",", 
        RowBox[{"paramsBase", "[", "\"\<c\>\"", "]"}]}], "]"}], ",", "wp"}], 
     "]"}]}], ";"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"params0", "=", 
    RowBox[{"promoteAssocPrecision", "[", 
     RowBox[{
      RowBox[{"Join", "[", 
       RowBox[{"paramsBase", ",", 
        RowBox[{"<|", 
         RowBox[{"\"\<A\>\"", "->", "Asep"}], "|>"}]}], "]"}], ",", "wp"}], 
     "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
     RowBox[{"solve", " ", "for", " ", "recurrence"}], "-", 
     RowBox[{"compatible", " ", "nu"}]}], ",", 
    RowBox[{"then", " ", "full", " ", "sequence"}]}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"nuSolve", "=", 
    RowBox[{"solveNuAndSequence", "[", 
     RowBox[{"nuSeed", ",", "params0", ",", 
      RowBox[{"WorkingPrecision", "->", "wp"}], ",", 
      RowBox[{"Cutoff", "->", "30"}], ",", 
      RowBox[{"BranchShiftRadius", "->", "4"}], ",", 
      RowBox[{"DefectTolerance", "->", 
       RowBox[{"10", "^", 
        RowBox[{"-", "30"}]}]}], ",", 
      RowBox[{"StepTolerance", "->", 
       RowBox[{"10", "^", 
        RowBox[{"-", "30"}]}]}], ",", 
      RowBox[{"MaxIterations", "->", "10"}], ",", 
      RowBox[{"MaxStepScale", "->", 
       RowBox[{"1", "/", "2"}]}], ",", 
      RowBox[{"Verbose", "->", "True"}], ",", 
      RowBox[{"InitialPositiveCutoff", "->", "40"}], ",", 
      RowBox[{"InitialNegativeCutoff", "->", 
       RowBox[{"-", "40"}]}], ",", 
      RowBox[{"CutoffStep", "->", "20"}], ",", 
      RowBox[{"TargetCentralDefect", "->", 
       RowBox[{"10", "^", 
        RowBox[{"-", "30"}]}]}], ",", 
      RowBox[{"TargetCoefficientChange", "->", 
       RowBox[{"10", "^", 
        RowBox[{"-", "25"}]}]}]}], "]"}]}], ";"}], "\n", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
   "extract", " ", "refined", " ", "nu", " ", "and", " ", "final", " ", 
    "recurrence", " ", "solution"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"nuBest", "=", 
   RowBox[{
    RowBox[{"nuSolve", "[", "\"\<FinalParams\>\"", "]"}], "[", 
    "\"\<\[Nu]\>\"", "]"}]}], ";"}], "\n", 
 RowBox[{
