          RowBox[{"iter", "++"}], ",", 
          RowBox[{
           RowBox[{"sol", "=", 
            RowBox[{"buildMSTSequence", "[", 
             RowBox[{"params", ",", 
              RowBox[{"WorkingPrecision", "->", "wp"}], ",", 
              RowBox[{"PositiveCutoff", "->", "nPlus"}], ",", 
              RowBox[{"NegativeCutoff", "->", "nMinus"}], ",", 
              RowBox[{"PositiveTailSeed", "->", "posSeed"}], ",", 
