       RowBox[{"sol", "[", "\"\<MaxScaledResidualAbs\>\"", "]"}]}]}], 
     "|>"}]}], ";"}], "\n", "\[IndentingNewLine]", 
  RowBox[{"(*", "amplitudes", "*)"}]}], "\[IndentingNewLine]", 
