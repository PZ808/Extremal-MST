           RowBox[{"{", 
            RowBox[{"nu", ",", "cands"}], "}"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"valid", "=", 
         RowBox[{"Select", "[", 
          RowBox[{"scored", ",", 
           RowBox[{
            RowBox[{
             RowBox[{"NumericQ", "[", 
