           RowBox[{"coeffOK", "=", 
            RowBox[{
             RowBox[{"NumericQ", "[", "coeffErr", "]"}], "&&", 
             RowBox[{"coeffErr", "<", "targetCoeff"}]}]}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{"defectOK", "&&", "coeffOK"}], ",", 
