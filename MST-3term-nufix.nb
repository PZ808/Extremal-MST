Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"INTRODUCE", " ", "THE", " ", "CLEBSCH"}], "-", 
    RowBox[{
    "GORDAN", " ", "COEFFICIENTS", " ", "AND", " ", "THE", " ", "NORMALIZED", 
     " ", "SPHEROIDAL", " ", "HARMONIC"}]}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"C1", "[", 
      RowBox[{"j_", ",", "s_", ",", "l_", ",", "m_"}], "]"}], ":=", 
     RowBox[{
      RowBox[{"Sqrt", "[", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"2", "l"}], "+", "1"}], ")"}], "/", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"2", "j"}], "+", "1"}], ")"}]}], "]"}], 
      RowBox[{"ClebschGordan", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"l", ",", "m"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"1", ",", "0"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"j", ",", "m"}], "}"}]}], "]"}], "*", 
      RowBox[{"ClebschGordan", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"l", ",", 
          RowBox[{"-", "s"}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"1", ",", "0"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"j", ",", 
          RowBox[{"-", "s"}]}], "}"}]}], "]"}]}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"C2", "[", 
      RowBox[{"j_", ",", "s_", ",", "l_", ",", "m_"}], "]"}], ":=", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "/", "3"}], ")"}], "*", 
       RowBox[{"KroneckerDelta", "[", 
        RowBox[{"j", ",", "l"}], "]"}]}], "+", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"2", "/", "3"}], ")"}], "*", 
       RowBox[{"Sqrt", "[", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"2", "l"}], "+", "1"}], ")"}], "/", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"2", "j"}], "+", "1"}], ")"}]}], "]"}], 
       RowBox[{"ClebschGordan", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"l", ",", "m"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"2", ",", "0"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"j", ",", "m"}], "}"}]}], "]"}], "*", 
       RowBox[{"ClebschGordan", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"l", ",", 
           RowBox[{"-", "s"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"2", ",", "0"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"j", ",", 
           RowBox[{"-", "s"}]}], "}"}]}], "]"}]}]}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"k1", "[", 
      RowBox[{"s_", ",", "l_", ",", "m_", ",", "a\[Omega]_"}], "]"}], ":=", 
     RowBox[{
      SuperscriptBox[
       RowBox[{"(", "a\[Omega]", ")"}], "2"], "*", 
      RowBox[{"C2", "[", 
       RowBox[{
        RowBox[{"l", "-", "2"}], ",", "s", ",", "l", ",", "m"}], "]"}]}]}], 
    ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"kTilde1", "[", 
      RowBox[{"s_", ",", "l_", ",", "m_", ",", "a\[Omega]_"}], "]"}], ":=", 
     RowBox[{
      RowBox[{
       SuperscriptBox[
        RowBox[{"(", "a\[Omega]", ")"}], "2"], "*", 
       RowBox[{"C2", "[", 
        RowBox[{
         RowBox[{"l", "-", "1"}], ",", "s", ",", "l", ",", "m"}], "]"}]}], 
      "-", 
      RowBox[{"2", "*", "a\[Omega]", "*", "s", "*", 
       RowBox[{"C1", "[", 
        RowBox[{
         RowBox[{"l", "-", "1"}], ",", "s", ",", "l", ",", "m"}], "]"}]}]}]}],
     ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"kHat", "[", 
      RowBox[{"s_", ",", "l_", ",", "m_", ",", "a\[Omega]_"}], "]"}], ":=", 
     RowBox[{
      RowBox[{
       SuperscriptBox[
        RowBox[{"(", "a\[Omega]", ")"}], "2"], "*", 
       RowBox[{"C2", "[", 
        RowBox[{"l", ",", "s", ",", "l", ",", "m"}], "]"}]}], "-", 
      RowBox[{"2", "*", "a\[Omega]", "*", "s", "*", 
       RowBox[{"C1", "[", 
        RowBox[{"l", ",", "s", ",", "l", ",", "m"}], "]"}]}], "-", 
      RowBox[{"l", 
       RowBox[{"(", 
        RowBox[{"l", "+", "1"}], ")"}]}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"kTilde2", "[", 
      RowBox[{"s_", ",", "l_", ",", "m_", ",", "a\[Omega]_"}], "]"}], ":=", 
