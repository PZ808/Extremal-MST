Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"chooseNuBranch", "[", 
    RowBox[{"alpha_", ",", "l_", ",", "params0_", ",", 
     RowBox[{"kmax_", ":", "4"}], ",", 
     RowBox[{"wp_", ":", "80"}]}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "cands", ",", "scored", ",", "params", ",", "r", ",", "ll", ",", 
       "defect"}], "}"}], ",", 
     RowBox[{
      RowBox[{"cands", "=", 
       RowBox[{"nuCandidates", "[", 
        RowBox[{"alpha", ",", "l", ",", "kmax"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"scored", "=", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"params", "=", 
           RowBox[{"Join", "[", 
            RowBox[{"params0", ",", 
             RowBox[{"<|", 
              RowBox[{"\"\<\[Nu]\>\"", "->", "nu"}], "|>"}]}], "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"defect", "=", 
           RowBox[{"Quiet", "@", 
            RowBox[{"Check", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"r", "=", 
                RowBox[{"computePositiveRatios", "[", 
                 RowBox[{"params", ",", "20", ",", 
                  RowBox[{"WorkingPrecision", "->", "wp"}]}], "]"}]}], ";", 
               "\[IndentingNewLine]", 
               RowBox[{"ll", "=", 
                RowBox[{"computeNegativeRatios", "[", 
                 RowBox[{"params", ",", 
                  RowBox[{"-", "20"}], ",", 
                  RowBox[{"WorkingPrecision", "->", "wp"}]}], "]"}]}], ";", 
               "\[IndentingNewLine]", 
               RowBox[{"Abs", "[", 
                RowBox[{"centralDefect", "[", 
                 RowBox[{"params", ",", "r", ",", "ll", ",", 
                  RowBox[{"WorkingPrecision", "->", "wp"}]}], "]"}], "]"}]}], 
              ",", "Infinity"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
          RowBox[{"{", 
           RowBox[{"nu", ",", "defect"}], "}"}]}], ",", 
         RowBox[{"{", 
          RowBox[{"nu", ",", "cands"}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"First", "@", 
