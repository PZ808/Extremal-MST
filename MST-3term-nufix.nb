                "|>"}], "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
           RowBox[{"coeffErr", "=", "Infinity"}], ";", "\[IndentingNewLine]", 
           
           RowBox[{"If", "[", 
            RowBox[{
