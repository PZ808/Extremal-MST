      RowBox[{
       SuperscriptBox[
        RowBox[{"(", "a\[Omega]", ")"}], "2"], "*", 
       RowBox[{"C2", "[", 
        RowBox[{
         RowBox[{"l", "+", "1"}], ",", "s", ",", "l", ",", "m"}], "]"}]}], 
      "-", 
      RowBox[{"2", "*", "a\[Omega]", "*", "s", "*", 
       RowBox[{"C1", "[", 
        RowBox[{
         RowBox[{"l", "+", "1"}], ",", "s", ",", "l", ",", "m"}], "]"}]}]}]}],
     ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
