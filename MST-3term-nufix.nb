 RowBox[{
  RowBox[{
   RowBox[{"wp", "=", "80"}], ";"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"toWP", "[", 
     RowBox[{"x_", ",", "wp_"}], "]"}], ":=", 
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{"NumericQ", "[", "x", "]"}], ",", 
      RowBox[{"SetPrecision", "[", 
       RowBox[{"x", ",", "wp"}], "]"}], ",", "x"}], "]"}]}], ";"}], 
