   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"SpinWeightedSphericalHarmonicY", "[", 
     RowBox[{"s_", ",", "l_", ",", "m_", ",", "th_", ",", "ph_"}], "]"}], ":=", 
    RowBox[{
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"-", "1"}], ")"}], "m"], "*", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"Sqrt", "[", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"1", "+", 
              RowBox[{"2", "*", "l"}]}], ")"}], "*", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"l", "-", "m"}], ")"}], "!"}], "*", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"l", "+", "m"}], ")"}], "!"}]}], ")"}], "/", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{
             RowBox[{"(", 
              RowBox[{"l", "-", "s"}], ")"}], "!"}], "*", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"l", "+", "s"}], ")"}], "!"}]}], ")"}]}], "]"}], "*", 
        RowBox[{"Piecewise", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{"(", 
                RowBox[{"-", "1"}], ")"}], "^", 
               RowBox[{"(", 
                RowBox[{"l", "-", "s"}], ")"}]}], "*", 
              RowBox[{"E", "^", 
               RowBox[{"(", 
                RowBox[{"I", "*", "m", "*", "ph"}], ")"}]}], "*", 
              RowBox[{"Binomial", "[", 
               RowBox[{
                RowBox[{"l", "+", "s"}], ",", 
                RowBox[{
                 RowBox[{"-", "m"}], "+", "s"}]}], "]"}], "*", 
              RowBox[{
               RowBox[{"Cot", "[", 
                RowBox[{"th", "/", "2"}], "]"}], "^", 
               RowBox[{"(", 
                RowBox[{
                 RowBox[{"-", "m"}], "+", "s"}], ")"}]}], "*", 
              RowBox[{"HypergeometricPFQ", "[", 
               RowBox[{
                RowBox[{"{", 
                 RowBox[{
                  RowBox[{
                   RowBox[{"-", "l"}], "-", "m"}], ",", 
                  RowBox[{
                   RowBox[{"-", "l"}], "+", "s"}]}], "}"}], ",", 
                RowBox[{"{", 
                 RowBox[{"1", "-", "m", "+", "s"}], "}"}], ",", 
                RowBox[{"-", 
                 RowBox[{
                  RowBox[{"Cot", "[", 
                   RowBox[{"th", "/", "2"}], "]"}], "^", "2"}]}]}], "]"}]}], 
             ",", 
             RowBox[{"m", "\[LessEqual]", "s"}]}], "}"}], "}"}], ",", 
          RowBox[{
           RowBox[{
            RowBox[{"(", 
             RowBox[{"-", "1"}], ")"}], "^", 
            RowBox[{"(", 
             RowBox[{"l", "-", "m"}], ")"}]}], "*", 
           RowBox[{"E", "^", 
            RowBox[{"(", 
             RowBox[{"I", "*", "m", "*", "ph"}], ")"}]}], "*", 
           RowBox[{"Binomial", "[", 
            RowBox[{
             RowBox[{"l", "-", "s"}], ",", 
             RowBox[{"m", "-", "s"}]}], "]"}], "*", 
           RowBox[{
            RowBox[{"Cot", "[", 
             RowBox[{"th", "/", "2"}], "]"}], "^", 
            RowBox[{"(", 
             RowBox[{"m", "-", "s"}], ")"}]}], "*", 
           RowBox[{"HypergeometricPFQ", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{
               RowBox[{
                RowBox[{"-", "l"}], "+", "m"}], ",", 
               RowBox[{
                RowBox[{"-", "l"}], "-", "s"}]}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"1", "+", "m", "-", "s"}], "}"}], ",", 
             RowBox[{"-", 
              RowBox[{
               RowBox[{"Cot", "[", 
                RowBox[{"th", "/", "2"}], "]"}], "^", "2"}]}]}], "]"}]}]}], 
         "]"}], "*", 
        RowBox[{
         RowBox[{"Sin", "[", 
          RowBox[{"th", "/", "2"}], "]"}], "^", 
         RowBox[{"(", 
          RowBox[{"2", "*", "l"}], ")"}]}]}], ")"}], "/", 
      RowBox[{"(", 
       RowBox[{"2", "*", 
        RowBox[{"Sqrt", "[", "Pi", "]"}]}], ")"}]}]}]}]}]}]], "Input",
