        ",", "EigenVals", ",", "i", ",", "EigenValPosition", ",", 
        "TrueEigenVector"}], "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"lmin", "=", 
        RowBox[{"Max", "[", 
         RowBox[{
          RowBox[{"Abs", "[", "s", "]"}], ",", 
          RowBox[{"Abs", "[", "m", "]"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Nmax", "=", 
        RowBox[{"l", "+", "kmax", "+", "M", "+", 
         RowBox[{"10", "*", 
          RowBox[{"Ceiling", "[", 
           RowBox[{"Log", "[", 
            RowBox[{
             RowBox[{"Abs", "[", "x", "]"}], "+", "1"}], "]"}], "]"}]}]}]}], 
       ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"TheMatrix", "=", 
        RowBox[{"Drop", "[", 
         RowBox[{
          RowBox[{"SparseArray", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{
               RowBox[{"{", 
                RowBox[{"i_", ",", "i_"}], "}"}], "\[Rule]", 
               RowBox[{"k1", "[", 
                RowBox[{"s", ",", 
                 RowBox[{"lmin", "+", "i", "-", "1"}], ",", "M", ",", "x"}], 
                "]"}]}], ",", 
              RowBox[{
               RowBox[{
                RowBox[{"{", 
                 RowBox[{"i_", ",", "j_"}], "}"}], "/;", 
                RowBox[{
                 RowBox[{"j", "-", "i"}], "\[Equal]", "1"}]}], "\[Rule]", 
               RowBox[{"kTilde1", "[", 
                RowBox[{"s", ",", 
                 RowBox[{"lmin", "+", "i", "-", "1"}], ",", "M", ",", "x"}], 
                "]"}]}], ",", 
              RowBox[{
               RowBox[{
                RowBox[{"{", 
                 RowBox[{"i_", ",", "j_"}], "}"}], "/;", 
                RowBox[{
                 RowBox[{"j", "-", "i"}], "\[Equal]", "2"}]}], "\[Rule]", 
               RowBox[{"kHat", "[", 
                RowBox[{"s", ",", 
                 RowBox[{"lmin", "+", "i", "-", "1"}], ",", "M", ",", "x"}], 
                "]"}]}], ",", 
              RowBox[{
               RowBox[{
                RowBox[{"{", 
                 RowBox[{"i_", ",", "j_"}], "}"}], "/;", 
                RowBox[{
                 RowBox[{"j", "-", "i"}], "\[Equal]", "3"}]}], "\[Rule]", 
               RowBox[{"kTilde2", "[", 
                RowBox[{"s", ",", 
                 RowBox[{"lmin", "+", "i", "-", "1"}], ",", "M", ",", "x"}], 
                "]"}]}], ",", 
              RowBox[{
               RowBox[{
                RowBox[{"{", 
                 RowBox[{"i_", ",", "j_"}], "}"}], "/;", 
                RowBox[{
                 RowBox[{"j", "-", "i"}], "\[Equal]", "4"}]}], "\[Rule]", 
               RowBox[{"k2", "[", 
                RowBox[{"s", ",", 
                 RowBox[{"lmin", "+", "i", "-", "1"}], ",", "M", ",", "x"}], 
                "]"}]}]}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{"Nmax", ",", "Nmax"}], "}"}]}], "]"}], ",", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"Nmax", "-", "1"}], ",", "Nmax"}], "}"}], ",", "2"}], 
         "]"}]}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"EigenValPosition", "=", 
        RowBox[{
         RowBox[{"Ordering", "[", 
          RowBox[{
           RowBox[{"Re", "[", 
            RowBox[{"Eigenvalues", "[", "TheMatrix", "]"}], "]"}], ",", 
           RowBox[{"{", 
            RowBox[{"l", "-", "lmin", "+", "1"}], "}"}], ",", "Greater"}], 
          "]"}], "[", 
         RowBox[{"[", "1", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"TrueEigenVector", "=", 
        RowBox[{"Re", "[", 
         RowBox[{
          RowBox[{"Eigensystem", "[", 
           RowBox[{"Normal", "[", "TheMatrix", "]"}], "]"}], "[", 
          RowBox[{"[", 
           RowBox[{"2", ",", "EigenValPosition"}], "]"}], "]"}], "]"}]}]}]}], 
     "\[IndentingNewLine]", "]"}]}]}], ";"}], "\[IndentingNewLine]"}], "Input",\

