                    RowBox[{"prevA", "[", "#", "]"}]}], "]"}], "&"}], "/@", 
                    "commonProbe"}], "]"}]}], ";"}]}], "]"}], ";"}]}], "]"}], 
           ";", "\[IndentingNewLine]", 
           RowBox[{"defectOK", "=", 
            RowBox[{
             RowBox[{"sol", "[", "\"\<CentralDefectAbs\>\"", "]"}], "<", 
